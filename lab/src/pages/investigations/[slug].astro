---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import StatusPill from "../../components/StatusPill.astro";
import EvidenceArtifacts from "../../components/EvidenceArtifacts.astro";
import Prose from "../../components/Prose.astro";

// URL comes from the frontmatter slug, not the filename, so renaming the
// content file does not change the route.
export async function getStaticPaths() {
  const entries = await getCollection("investigations");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const started = d.started.toISOString().slice(0, 10);
const updated = d.updated.toISOString().slice(0, 10);

const title = `${d.title} | The AI Runtime Lab`;
---

<Base title={title} description={d.summary} ogType="article">
  <article class="container detail">
    <header class="detail__head reading">
      <div class="detail__top">
        <span class="mono-label">Investigation {d.id}</span>
        <StatusPill status={d.status} />
      </div>
      <h1>{d.title}</h1>
      <p class="detail__question">{d.question}</p>
      <dl class="detail__dates">
        <div>
          <dt class="mono-label">Started</dt>
          <dd><time datetime={started}>{started}</time></dd>
        </div>
        <div>
          <dt class="mono-label">Updated</dt>
          <dd><time datetime={updated}>{updated}</time></dd>
        </div>
        {d.pillar && (
          <div>
            <dt class="mono-label">Pillar</dt>
            <dd>{d.pillar}</dd>
          </div>
        )}
      </dl>
    </header>

    <section class="problem reading" aria-labelledby="problem-heading">
      <h2 id="problem-heading">The problem</h2>
      <dl class="problem__grid">
        <div>
          <dt class="mono-label">Customer</dt>
          <dd>{d.customer}</dd>
        </div>
        <div>
          <dt class="mono-label">Problem</dt>
          <dd>{d.problem}</dd>
        </div>
        <div>
          <dt class="mono-label">The question</dt>
          <dd class="problem__question">{d.question}</dd>
        </div>
      </dl>
    </section>

    <div class="reading">
      <EvidenceArtifacts
        repo={d.repo}
        evalUrl={d.evalUrl}
        datasetUrl={d.datasetUrl}
        reportUrl={d.reportUrl}
      />
    </div>

    <Prose>
      <Content />
    </Prose>

    {d.tags.length > 0 && (
      <footer class="detail__footer reading">
        <h2 class="mono-label">Tags</h2>
        <ul class="detail__tags">
          {d.tags.map((t) => <li class="tag">{t}</li>)}
        </ul>
      </footer>
    )}
  </article>
</Base>

<style>
  .detail { padding: 3rem 0 1rem; }
  .detail__head { margin-bottom: 2.5rem; }
  .detail__top {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }
  .detail__head h1 { margin: 0 0 0.8rem; }

  /* The question is prominent beneath the title. */
  .detail__question {
    font-family: var(--font-mono);
    font-size: clamp(1.1rem, 2.4vw, 1.4rem);
    line-height: 1.35;
    color: var(--accent);
    margin: 0 0 1.6rem;
  }

  .detail__dates {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2.5rem;
    margin: 0;
  }
  .detail__dates dt { margin-bottom: 0.2rem; }
  .detail__dates dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--text-2);
  }

  /* Lead-with-the-problem block, visually prominent. */
  .problem {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 1.6rem 1.8rem;
    margin: 0 0 0.5rem;
  }
  .problem h2 {
    font-size: 1.1rem;
    margin: 0 0 1.2rem;
  }
  .problem__grid {
    display: grid;
    gap: 1.1rem;
    margin: 0;
  }
  .problem__grid dt { margin-bottom: 0.25rem; }
  .problem__grid dd {
    margin: 0;
    color: var(--text);
  }
  .problem__question {
    font-family: var(--font-mono);
    color: var(--accent) !important;
  }

  .detail__footer { margin-top: 3rem; }
  .detail__footer h2 { margin-bottom: 0.8rem; }
  .detail__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }
</style>
