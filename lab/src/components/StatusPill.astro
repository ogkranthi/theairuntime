---
// Three states only:
//   investigating -> orange outline
//   in-eval       -> muted (--text-2) outline
//   published     -> solid --accent fill with --bg text
interface Props {
  status: "investigating" | "in-eval" | "published";
}
const { status } = Astro.props;
const label = status;
---

<span class={`pill pill--${status}`} data-status={status}>{label}</span>

<style>
  .pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    white-space: nowrap;
    line-height: 1.4;
  }
  .pill--investigating {
    color: var(--accent);
    border: 1px solid var(--accent);
    background: transparent;
  }
  .pill--in-eval {
    color: var(--text-2);
    border: 1px solid var(--text-2);
    background: transparent;
  }
  .pill--published {
    color: var(--bg);
    border: 1px solid var(--accent);
    background: var(--accent);
  }
</style>
