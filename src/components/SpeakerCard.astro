---
import type { CollectionEntry } from 'astro:content';

interface Props {
  speaker: CollectionEntry<'speakers'>;
  eventSlug?: string;
  showLink?: boolean;
}

const { speaker, eventSlug, showLink = true } = Astro.props;
const data = speaker.data;
const talk = eventSlug ? data.talks.find((t) => t.eventSlug === eventSlug) : data.talks[0];
const initials = data.name.split(' ').map((p) => p[0]).slice(0, 2).join('');
---
<article class="speaker">
  <div class="head">
    <div class="avatar">
      {data.photo ? (
        <img src={data.photo} alt={data.name} loading="lazy" />
      ) : (
        <span>{initials}</span>
      )}
    </div>
    <div>
      <div class="name">{data.name}</div>
      <div class="role muted">{data.title} · {data.company}</div>
    </div>
  </div>

  {talk && (
    <div class="talk">
      <div class="tag">Talk</div>
      <h3 class="title">{talk.title}</h3>
      <p class="dim">{talk.abstract}</p>
    </div>
  )}

  {showLink && (
    <a class="more muted" href={`/speakers/${speaker.slug}`}>Speaker profile →</a>
  )}
</article>

<style>
  .speaker {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .head { display: flex; gap: 1rem; align-items: center; }
  .avatar {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-weight: 700;
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }
  .name { font-family: var(--font-mono); font-weight: 700; font-size: 1.05rem; }
  .role { font-size: 0.9rem; }
  .talk .title { margin: 0.5rem 0; }
  .more { font-family: var(--font-mono); font-size: 0.85rem; }
</style>
