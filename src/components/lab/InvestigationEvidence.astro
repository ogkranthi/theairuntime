---
import type { InvestigationData, Metrics } from "../../data/investigation-01";

interface Props {
  data: InvestigationData;
}
const { data } = Astro.props;
const { status, baseline, treatment, decision, surprise, failures, build } = data;

const pct = (x: number | null) => (x == null ? null : `${Math.round(x * 100)}%`);
const usd = (x: number | null) => (x == null ? null : `$${x.toFixed(2)}`);
const int = (x: number | null) => (x == null ? null : String(x));

// Row cells in display order. The gate metric (precision) is highlighted when
// a real number exists; everything else is plain text. Pending cells render an
// em-free dash placeholder, never a number.
const cells = (m: Metrics) => [
  { v: pct(m.precision), gate: true },
  { v: pct(m.recall), gate: false },
  { v: usd(m.costPerQualified), gate: false },
  { v: int(m.weeklyThroughput), gate: false },
];

const statusLabel =
  status === "running" ? "Running" : status === "decided" ? "Decided" : "Baseline pending";

// The build stamp shows whatever is real (stack chips, repo and harness links)
// and hides the metric stamps until they are measured. The section appears when
// there is anything real to show.
const hasBuildLinks = Boolean(build.repoUrl || build.harnessUrl);
const showBuild = hasBuildLinks || build.loc != null || build.stack.length > 0;
---

{/* 1. Status strip */}
<section class="strip" aria-label="Status">
  <div class="strip__slot">
    <span class="mono-label">Status</span>
    <span class="strip__status" data-status={status}>
      <span class={`dot dot--${status}`} aria-hidden="true"></span>{statusLabel}
    </span>
  </div>
  <div class="strip__slot">
    <span class="mono-label">Question</span>
    <span class="strip__val">{data.question}</span>
  </div>
  <div class="strip__slot">
    <span class="mono-label">Reliability bar</span>
    <span class="strip__val">{data.bar}</span>
  </div>
</section>

{/* 2. Results */}
<section class="ev" aria-labelledby="results-heading">
  <h2 id="results-heading">Results</h2>
  <div class="table-wrap">
    <table class="results">
      <thead>
        <tr>
          <th scope="col"></th>
          <th scope="col">Precision</th>
          <th scope="col">Recall</th>
          <th scope="col">Cost / qualified</th>
          <th scope="col">Weekly throughput</th>
        </tr>
      </thead>
      <tbody>
        {[
          { label: "Baseline", m: baseline },
          { label: "Treatment", m: treatment },
        ].map(({ label, m }) => (
          <tr>
            <th scope="row">{label}</th>
            {cells(m).map((c) => (
              <td class={c.v == null ? "cell-pending" : c.gate ? "cell-gate" : "cell-num"}>
                {c.v ?? "--"}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  {baseline.state === "pending" && (
    <p class="ev__note">
      Baseline run pending. Numbers populate from the eval harness on the next
      run; nothing here is hand-entered.
    </p>
  )}
</section>

{/* 3. Decision */}
<section class="ev" aria-labelledby="decision-heading">
  {decision.state === "pending" ? (
    <>
      <h2 id="decision-heading">Decision: pending</h2>
      <p>
        Held until baseline and treatment clear the harness. The decision is
        whether this is worth deploying for the seed customer, not whether the
        demo runs.
      </p>
    </>
  ) : (
    <>
      <h2 id="decision-heading">Decision</h2>
      <p class="verdict" data-verdict={decision.state}>
        {decision.state === "ship" ? "Ship it." : "Do not ship it."}
      </p>
      {decision.reason && <p>{decision.reason}</p>}
    </>
  )}
</section>

{/* 4. What surprised me */}
<section class="ev" aria-labelledby="surprise-heading">
  <h2 id="surprise-heading">What surprised me</h2>
  {surprise ? (
    <p>{surprise}</p>
  ) : (
    <p class="ev__pending">
      Pending the baseline run. This section reports the result that
      contradicted the hypothesis, not the one that confirmed it. The rubric is
      frozen (DR-002) so the surprise can be a real one.
    </p>
  )}
</section>

{/* 5. Failure gallery */}
<section class="ev" aria-labelledby="failures-heading">
  <h2 id="failures-heading">Failure gallery</h2>
  {failures.length > 0 ? (
    <ul class="failures">
      {failures.map((f) => (
        <li class="failure">
          <p class="failure__candidate">{f.candidate}</p>
          <dl class="failure__grid">
            <dt class="mono-label">Agent said</dt>
            <dd>{f.modelClaim}</dd>
            <dt class="mono-label">Reality</dt>
            <dd>{f.reality}</dd>
            <dt class="mono-label">Failure</dt>
            <dd><span class="failure__class">{f.failureClass}</span></dd>
          </dl>
        </li>
      ))}
    </ul>
  ) : (
    <p class="ev__pending">
      No failure rows yet. They get pulled straight from the baseline run's
      wrong outputs, verbatim, once it completes.
    </p>
  )}
</section>

{/* 6. What I built */}
{showBuild && (
  <section class="ev" aria-labelledby="build-heading">
    <h2 id="build-heading">What I built</h2>
    <p class="build__intro">
      The smallest system that can test the thesis, built to be thrown away if
      the thesis is wrong.
    </p>

    {(build.buildTime || build.loc != null) && (
      <dl class="build__stats">
        {build.buildTime && (
          <div>
            <dt class="mono-label">Build time</dt>
            <dd>{build.buildTime}</dd>
          </div>
        )}
        {build.loc != null && (
          <div>
            <dt class="mono-label">Lines of code</dt>
            <dd>{build.loc}</dd>
          </div>
        )}
      </dl>
    )}

    {build.stack.length > 0 && (
      <ul class="build__stack" aria-label="Stack">
        {build.stack.map((s) => <li class="tag">{s}</li>)}
      </ul>
    )}

    {hasBuildLinks && (
      <div class="build__links">
        {build.repoUrl && (
          <a class="ev-btn" href={build.repoUrl} rel="noopener">Code<span aria-hidden="true"> -&gt;</span></a>
        )}
        {build.harnessUrl && (
          <a class="ev-btn" href={build.harnessUrl} rel="noopener">Eval harness<span aria-hidden="true"> -&gt;</span></a>
        )}
      </div>
    )}
  </section>
)}

<style>
  /* Status strip */
  .strip {
    display: grid;
    grid-template-columns: auto 1.4fr 1.6fr;
    gap: 1.5rem 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-2);
    padding: 1.2rem 1.4rem;
    margin: 0 0 2.5rem;
  }
  .strip__slot { display: flex; flex-direction: column; gap: 0.35rem; min-width: 0; }
  .strip__status {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .dot { width: 0.6rem; height: 0.6rem; border-radius: 999px; display: inline-block; }
  .dot--running { background: var(--accent); }
  .dot--planned { background: var(--text-3); }
  .dot--decided { background: var(--accent); }
  .strip__val { font-size: 0.95rem; color: var(--text-2); line-height: 1.5; }

  /* Shared evidence section spacing */
  .ev { margin: 0 0 2.6rem; }
  .ev h2 { margin: 0 0 1rem; }
  .ev__note {
    margin: 0.9rem 0 0;
    font-size: 0.92rem;
    color: var(--text-3);
  }
  .ev__pending {
    color: var(--text-3);
    border-left: 2px solid var(--border);
    padding-left: 1rem;
    margin: 0;
  }

  /* Results table */
  .table-wrap { overflow-x: auto; }
  .results {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }
  .results th,
  .results td {
    text-align: right;
    padding: 0.65rem 0.9rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .results thead th {
    color: var(--text-3);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.02em;
  }
  .results thead th:first-child,
  .results tbody th { text-align: left; }
  .results tbody th { color: var(--text); font-weight: 600; }
  .cell-pending { color: var(--text-3); }
  .cell-num { color: var(--text); }
  .cell-gate { color: var(--accent); font-weight: 700; }

  /* Decision */
  .verdict {
    font-family: var(--font-mono);
    font-size: 1.3rem;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }
  .verdict[data-verdict="no-ship"] { color: var(--text); }

  /* Failure gallery */
  .failures { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem; }
  .failure {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-2);
    padding: 1.2rem 1.3rem;
  }
  .failure__candidate {
    font-family: var(--font-mono);
    color: var(--text);
    margin: 0 0 0.8rem;
  }
  .failure__grid {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 0.5rem 1rem;
    margin: 0;
  }
  .failure__grid dd { margin: 0; color: var(--text-2); }
  .failure__class {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
  }

  /* What I built */
  .build__intro { color: var(--text-2); margin: 0 0 1.2rem; }
  .build__stats { display: flex; flex-wrap: wrap; gap: 1.5rem 2.5rem; margin: 0 0 1.2rem; }
  .build__stats dt { margin-bottom: 0.2rem; }
  .build__stats dd { margin: 0; font-family: var(--font-mono); color: var(--text); }
  .build__stack { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 0 0 1.3rem; padding: 0; }
  .build__links { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .ev-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.55rem 1.1rem;
    text-decoration: none;
  }
  .ev-btn:hover { border-color: var(--accent); text-decoration: none; }

  @media (max-width: 640px) {
    .strip { grid-template-columns: 1fr; gap: 1.1rem; }
    .failure__grid { grid-template-columns: 1fr; gap: 0.15rem 0; }
    .failure__grid dt { margin-top: 0.5rem; }
  }
</style>
