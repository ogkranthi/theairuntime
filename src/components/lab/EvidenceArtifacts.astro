---
// Evidence artifacts block. Render only artifacts that have a URL, and hide the
// whole block if none do. Placed high on the detail page so a reviewer finds
// the code fast.
interface Props {
  repo?: string;
  evalUrl?: string;
  datasetUrl?: string;
  reportUrl?: string;
}
const { repo, evalUrl, datasetUrl, reportUrl } = Astro.props;

const artifacts = [
  { label: "Code", url: repo },
  { label: "Eval harness", url: evalUrl },
  { label: "Dataset / labels", url: datasetUrl },
  { label: "Final report", url: reportUrl },
].filter((a): a is { label: string; url: string } => Boolean(a.url));
---

{artifacts.length > 0 && (
  <section class="evidence" aria-labelledby="evidence-heading">
    <h2 id="evidence-heading">Evidence artifacts</h2>
    <ul class="evidence__list">
      {artifacts.map((a) => (
        <li>
          <a href={a.url} rel="noopener">
            <span class="evidence__label">{a.label}</span>
            <span class="evidence__arrow" aria-hidden="true">-&gt;</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .evidence {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-2);
    padding: 1.4rem 1.6rem;
    margin: 2.5rem 0;
  }
  .evidence h2 {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin: 0 0 1rem;
  }
  .evidence__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.25rem;
  }
  .evidence__list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 0;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    color: var(--text);
  }
  .evidence__list li:first-child a { border-top: none; }
  .evidence__list a:hover { color: var(--accent); text-decoration: none; }
  .evidence__arrow { color: var(--accent); }
</style>
