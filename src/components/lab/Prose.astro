---
// Wraps rendered markdown body so prose styling is scoped to the dark Lab theme.
---

<div class="prose reading">
  <slot />
</div>

<style is:global>
  .prose { color: var(--text-2); }
  .prose h2 { margin-top: 2.6rem; padding-top: 0.2rem; scroll-margin-top: 1rem; }
  .prose h3 { margin-top: 1.8rem; color: var(--text); }
  .prose h2 + p,
  .prose h3 + p { margin-top: 0; }
  .prose p { margin: 0 0 1.15em; }
  .prose a { color: var(--accent); }
  .prose ul,
  .prose ol { margin: 0 0 1.2em; padding-left: 1.3rem; }
  .prose li { margin: 0.35em 0; }
  .prose blockquote {
    margin: 1.5rem 0;
    padding: 0.4rem 0 0.4rem 1.1rem;
    border-left: 2px solid var(--accent);
    color: var(--text-2);
  }
  .prose blockquote p:last-child { margin-bottom: 0; }
  .prose hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
  .prose th,
  .prose td { text-align: left; padding: 0.5rem 0.7rem; border-bottom: 1px solid var(--border); }
  .prose th { font-family: var(--font-mono); color: var(--text); font-weight: 600; }
</style>
