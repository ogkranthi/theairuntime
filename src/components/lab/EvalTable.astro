---
// A small, left-aligned categorical table for the Dirty Thirty grading grid.
// Scrolls horizontally on narrow screens. Lab tokens inherit from LabLayout.
interface Props {
  headers: string[];
  rows: (string | number)[][];
}
const { headers, rows } = Astro.props;
---
<div class="table-wrap">
  <table class="eval">
    <thead>
      <tr>{headers.map((h) => <th scope="col">{h}</th>)}</tr>
    </thead>
    <tbody>
      {rows.map((r) => (
        <tr>{r.map((cell) => <td>{cell}</td>)}</tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-wrap { overflow-x: auto; }
  .eval {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .eval th,
  .eval td {
    text-align: left;
    padding: 0.65rem 0.9rem;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .eval thead th {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-3);
    font-weight: 600;
  }
  .eval tbody td:first-child {
    font-family: var(--font-mono);
    color: var(--text);
  }
  .eval td { color: var(--text-2); }
</style>
