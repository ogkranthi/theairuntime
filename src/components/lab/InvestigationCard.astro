---
import StatusPill from "./StatusPill.astro";
import StageTimeline from "./StageTimeline.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"investigations">;
}
const { entry } = Astro.props;
const d = entry.data;

const updated = d.updated.toISOString().slice(0, 10);
// The title is intentionally NOT shown on the card. The question is the focus.
---

<a class="card" href={`/investigations/${d.slug}`}>
  <div class="card__top">
    <span class="mono-label">FR-{d.id.padStart(3, "0")}</span>
    <StatusPill status={d.status} />
  </div>

  <h2 class="card__question">{d.question}</h2>

  <StageTimeline stages={d.stages} compact />

  <dl class="card__meta">
    {d.industry && (
      <div>
        <dt class="mono-label">Industry</dt>
        <dd>{d.industry}</dd>
      </div>
    )}
    <div>
      <dt class="mono-label">Customer</dt>
      <dd>{d.customer}</dd>
    </div>
    <div>
      <dt class="mono-label">Updated</dt>
      <dd><time datetime={updated}>{updated}</time></dd>
    </div>
  </dl>

  {d.tags.length > 0 && (
    <ul class="card__tags">
      {d.tags.map((t) => <li class="tag">{t}</li>)}
    </ul>
  )}
</a>

<style>
  .card {
    display: block;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.6rem 1.6rem 1.4rem;
    color: inherit;
    text-decoration: none;
    transition: border-color 140ms ease;
  }
  .card:hover { border-color: var(--accent); text-decoration: none; }

  .card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* The question is the largest element on the card. */
  .card__question {
    font-size: clamp(1.3rem, 2.6vw, 1.7rem);
    line-height: 1.25;
    color: var(--text);
    margin: 0 0 0.5rem;
  }

  .card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
    margin: 1.3rem 0 1.1rem;
  }
  .card__meta div { margin: 0; }
  .card__meta dt { margin-bottom: 0.2rem; }
  .card__meta dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--text-2);
  }

  .card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }
</style>
