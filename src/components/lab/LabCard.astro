---
// A linked card for a Field Lab, used on the home and any Lab index.
interface Props {
  number: number;
  title: string;
  status: 'scheduled' | 'past' | 'draft';
  brief_summary: string;
  partner?: string;
  date?: Date;
}
const { number, title, status, brief_summary, partner, date } = Astro.props;
const nn = String(number).padStart(2, '0');
const dateLabel = date
  ? new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(date)
  : null;
const statusLabel = status === 'scheduled' ? 'Upcoming' : status === 'past' ? 'Past' : 'Draft';
---
<a class="lab-card" href={`/${nn}`}>
  <div class="top">
    <span class="nn">Field Lab {nn}</span>
    <span class:list={['status', status]}>{statusLabel}</span>
  </div>
  <h3>{title}</h3>
  <p class="summary">{brief_summary}</p>
  <p class="meta">
    {partner && <span>with {partner}</span>}
    {dateLabel && <span>{dateLabel}</span>}
  </p>
</a>

<style>
  .lab-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-2);
    padding: 1.4rem 1.5rem;
    color: var(--text);
    text-decoration: none;
    transition: border-color 140ms ease;
  }
  .lab-card:hover { border-color: var(--accent); text-decoration: none; }
  .top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .nn { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-3); }
  .status {
    font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.15rem 0.55rem; border-radius: 999px; border: 1px solid var(--border-strong); color: var(--text-2);
  }
  .status.scheduled { border-color: var(--accent); color: var(--accent); }
  h3 { margin: 0.7rem 0 0.5rem; font-size: 1.1rem; }
  .summary { margin: 0; color: var(--text-2); font-size: 0.95rem; line-height: 1.6; }
  .meta { display: flex; flex-wrap: wrap; gap: 1.2rem; margin: 0.9rem 0 0; font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-3); }
</style>
