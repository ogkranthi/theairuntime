---
/**
 * StatBand: a tight row of headline community numbers. Two big, honest stats
 * read stronger than several small ones. Keep these current.
 */
interface Stat {
  value: string;
  label: string;
}
interface Props {
  stats?: Stat[];
  note?: string;
}
const {
  stats = [
    { value: '17K+', label: 'AI practitioners on LinkedIn' },
    { value: '2,000+', label: 'newsletter subscribers' },
  ],
  note = 'Plus 200+ practitioners who show up in person at the Boston meetup.',
} = Astro.props;
---
<div class="statband">
  <div class="container">
    <ul role="list">
      {stats.map((s) => (
        <li>
          <span class="value">{s.value}</span>
          <span class="label">{s.label}</span>
        </li>
      ))}
    </ul>
    {note && <p class="note">{note}</p>}
  </div>
</div>

<style>
  .statband { padding: 2.75rem 0; }
  .statband ul {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem 5rem;
    text-align: center;
  }
  .statband li { display: flex; flex-direction: column; gap: 0.3rem; }
  .value {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(2.6rem, 7vw, 4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--accent);
  }
  .label {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .note {
    text-align: center;
    color: var(--text-3);
    font-size: 0.92rem;
    margin: 1.5rem auto 0;
    max-width: 36rem;
  }
</style>
