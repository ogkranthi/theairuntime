---
import type { CollectionEntry } from 'astro:content';
import Blink from './Blink.astro';

interface Props {
  event: CollectionEntry<'events'>;
}

const { event } = Astro.props;
const data = event.data;

const dateFmt = new Intl.DateTimeFormat('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(data.date);

// Photo-forward cover when one is available; otherwise fall back to the mascot.
const cover = data.cover ?? data.recapPhotos?.[0]?.src ?? null;
const upcoming = data.status === 'upcoming';
---
<section class:list={['hero', { 'has-cover': cover }]}>
  <div class="container">
    {cover && (
      <div class="cover">
        <img src={cover} alt={`${data.title}, The AI Runtime Boston`} loading="eager" decoding="async" />
      </div>
    )}
    <div class="grid">
      <div class="copy">
        <span class="tag">{upcoming ? 'Upcoming in Boston' : 'Past event'}</span>
        <h1>{data.title}</h1>
        <ul class="meta">
          <li>{dateFmt}</li>
          {data.doorsAt && <li>Doors {data.doorsAt}{data.endsAt ? ` to ${data.endsAt}` : ''}</li>}
          {data.venue?.name && (
            <li>
              {data.venue.mapUrl
                ? <a href={data.venue.mapUrl} target="_blank" rel="noopener">{data.venue.name}</a>
                : data.venue.name}
            </li>
          )}
        </ul>
        {data.description && <p class="lede dim">{data.description}</p>}
        <div class="ctas">
          {data.lumaUrl && <a class="btn" href={data.lumaUrl} target="_blank" rel="noopener">RSVP on Luma</a>}
          <a class="btn btn-ghost" href="#agenda">See agenda</a>
        </div>
      </div>
      {!cover && (
        <div class="art"><Blink size={140} showMotion={true} showCheeks={true} /></div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(ellipse at top right, rgba(251, 146, 60, 0.08), transparent 55%),
      var(--bg);
  }
  .cover {
    width: 100%;
    height: clamp(220px, 38vw, 440px);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .grid { display: grid; gap: 2rem; align-items: center; }
  .hero:not(.has-cover) .grid { grid-template-columns: 1.4fr 1fr; }
  @media (max-width: 720px) {
    .hero:not(.has-cover) .grid { grid-template-columns: 1fr; }
    .art { order: -1; }
  }
  h1 { margin-top: 0.6rem; }
  .meta {
    list-style: none; padding: 0; margin: 0.9rem 0 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem;
  }
  .meta li {
    font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-2);
    border: 1px solid var(--border); border-radius: 999px; padding: 0.3rem 0.75rem;
  }
  .meta a { color: var(--accent); text-decoration: none; }
  .lede { margin-top: 1rem; font-size: 1.05rem; max-width: 40rem; }
  .ctas { display: flex; gap: 0.75rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .art { display: flex; justify-content: center; }
</style>
