---
/**
 * CohortCTA: the "Field Lab" pilot signup section for students.
 *
 * Self-contained and scoped: drop it on any page. A distinctive dark band that
 * stands apart from the light site, using the section design tokens locally so
 * nothing leaks. One join action is driven by a single config value
 * (PUBLIC_COHORT_JOIN_URL). An optional inline waitlist form posts to
 * /api/waitlist with progressive enhancement, and degrades to the join link
 * when JavaScript is off or the backend is not enabled.
 */
const joinUrl =
  import.meta.env.PUBLIC_COHORT_JOIN_URL ||
  'mailto:info@theairuntime.com?subject=Field%20Lab%20pilot';

const gates = [
  {
    n: '01',
    title: 'Pick a real problem',
    body: 'Choose a focused, real-world task worth solving. Write down what good looks like and where it could go wrong before you build.',
  },
  {
    n: '02',
    title: 'Build something grounded',
    body: 'Go from idea to a working build, grounded in real sources. The goal is something that holds up beyond a hand-picked demo.',
  },
  {
    n: '03',
    title: 'Measure reliability',
    body: 'Add the checks and signals that tell you when it works and when it breaks. Reliability is measured, not claimed.',
  },
  {
    n: '04',
    title: 'Show your work',
    body: 'Share a short demo with the community. Walk through the problem, your approach, and one thing you learned.',
  },
];
---
<section id="cohort" class="cohort" aria-labelledby="cohort-title">
  <div class="cohort-inner">
    <p class="kicker">The AI Runtime · Field Lab Pilot</p>
    <h2 id="cohort-title">Build something real with AI, on your own clock.</h2>
    <p class="lede">
      The Field Lab is a free, async pilot for a small group of motivated student builders. Work
      through a real project at your own pace, learn what production reliability actually takes, and
      share what you build with the community. Small groups per run. Exact scope and format are
      still taking shape, join the list and we'll shape it together.
    </p>

    <ol class="gates">
      {gates.map((g) => (
        <li class="gate">
          <span class="gate-n">{g.n}</span>
          <h3>{g.title}</h3>
          <p>{g.body}</p>
        </li>
      ))}
    </ol>

    <div class="payoff">
      <p>
        We're shaping a credential that recognizes how far you take it, from a first working build
        to an agent that catches and corrects its own mistakes.
      </p>
    </div>

    <div class="join">
      <form class="waitlist" action={joinUrl} method="get" target="_blank" novalidate>
        <label class="vh" for="cohort-email">Your email</label>
        <input
          id="cohort-email"
          class="wl-email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@school.edu"
        />
        <button class="btn btn-primary wl-submit" type="submit">Join the Field Lab</button>
      </form>
      <p class="join-sub">
        Limited spots per run. If the current run is full, you join a rolling waitlist and we email
        you when the next one opens.
      </p>
      <p class="wl-status" role="status" aria-live="polite" hidden></p>
    </div>
  </div>
</section>

<script>
  // Progressive enhancement: if JS runs, capture the email on-page via
  // /api/waitlist and show a success state. If JS is off, the anchor link
  // (PUBLIC_COHORT_JOIN_URL) is what the visitor uses instead.
  document.querySelectorAll<HTMLFormElement>('.waitlist').forEach((form) => {
    const submit = form.querySelector<HTMLButtonElement>('.wl-submit');
    const email = form.querySelector<HTMLInputElement>('.wl-email');
    const status = form.parentElement?.querySelector<HTMLElement>('.wl-status');
    // With JS off, the form's action/target sends the visitor to the join URL.
    const joinUrl = form.getAttribute('action') || '';

    function show(msg: string) {
      if (!status) return;
      status.textContent = msg;
      status.hidden = false;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const value = (email?.value || '').trim();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
        show('Please enter a valid email.');
        return;
      }
      if (submit) submit.disabled = true;
      show('Adding you...');
      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: value }),
        });
        if (res.ok) {
          form.hidden = true;
          show("You're on the list. We'll email you when the next run opens.");
          return;
        }
      } catch {
        /* fall through to the handoff below */
      }
      // Backend unavailable: hand off to the configured join URL.
      if (submit) submit.disabled = false;
      if (joinUrl) {
        show('Opening the signup...');
        window.open(joinUrl, '_blank', 'noopener');
      } else {
        show('Something went wrong. Email info@theairuntime.com to join.');
      }
    });
  });
</script>

<style>
  /* Cohort design tokens, scoped to this section so they never leak. */
  .cohort {
    --c-bg: #161616;
    --c-text: #ece6dc;
    --c-muted: #bdb6ab;
    --c-faint: #8a857c;
    --c-accent: #e8852b;
    --c-accent-hover: #f5a04f;
    --c-heading: #fefcf8;
    --c-serif: Georgia, 'Times New Roman', serif;
    --c-sans: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;

    background: var(--c-bg);
    color: var(--c-text);
    padding: 5rem 0;
  }
  .cohort-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .kicker {
    font-family: var(--c-sans);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-accent);
    margin: 0 0 1rem;
    font-weight: 600;
  }
  .cohort h2 {
    font-family: var(--c-serif);
    color: var(--c-heading);
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
    max-width: 22ch;
  }
  .lede {
    font-family: var(--c-sans);
    color: var(--c-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 44rem;
    margin: 0 0 2.75rem;
  }

  .gates {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .gates { grid-template-columns: 1fr; }
  }
  .gate {
    padding: 1.5rem;
    border: 1px solid rgba(236, 230, 220, 0.12);
    border-radius: 12px;
    background: rgba(236, 230, 220, 0.03);
  }
  .gate-n {
    font-family: var(--c-sans);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--c-accent);
  }
  .gate h3 {
    font-family: var(--c-serif);
    color: var(--c-heading);
    font-size: 1.2rem;
    margin: 0.4rem 0 0.5rem;
  }
  .gate p {
    font-family: var(--c-sans);
    color: var(--c-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .payoff {
    border-left: 3px solid var(--c-accent);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 0 0 2.5rem;
    max-width: 44rem;
  }
  .payoff p {
    font-family: var(--c-serif);
    color: var(--c-text);
    font-size: 1.15rem;
    line-height: 1.6;
    margin: 0;
  }

  .join { max-width: 44rem; }
  .waitlist {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .wl-email {
    flex: 1 1 16rem;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    border: 1px solid rgba(236, 230, 220, 0.2);
    background: rgba(236, 230, 220, 0.05);
    color: var(--c-text);
    font-family: var(--c-sans);
    font-size: 0.95rem;
  }
  .wl-email::placeholder { color: var(--c-faint); }
  .wl-email:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 2px;
    border-color: var(--c-accent);
  }
  .btn-primary {
    display: inline-block;
    padding: 0.85rem 1.6rem;
    border-radius: 8px;
    background: var(--c-accent);
    color: #161616;
    border: 1px solid var(--c-accent);
    font-family: var(--c-sans);
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    text-decoration: none;
    transition: background 140ms ease, border-color 140ms ease;
  }
  .btn-primary:hover {
    background: var(--c-accent-hover);
    border-color: var(--c-accent-hover);
    text-decoration: none;
  }
  .btn-primary:focus-visible {
    outline: 2px solid var(--c-heading);
    outline-offset: 2px;
  }
  .btn-primary[disabled] { opacity: 0.6; cursor: not-allowed; }
  .join-sub {
    font-family: var(--c-sans);
    color: var(--c-faint);
    font-size: 0.85rem;
    margin: 0.85rem 0 0;
    max-width: 40rem;
    line-height: 1.6;
  }
  .wl-status {
    font-family: var(--c-sans);
    color: var(--c-accent);
    font-size: 0.95rem;
    margin: 0.85rem 0 0;
  }
  .vh {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
</style>
