---
import Blink from './Blink.astro';
---
<footer class="ftr">
  <div class="container">
    <div class="grid">
      <div class="brand">
        <Blink size={36} showMotion={false} />
        <p class="dim">A community of AI practitioners. Read, meet, and build, together.</p>
        <p class="muted small">LEARN. SHIP. RUN.</p>
      </div>

      <div>
        <h4>Read &amp; listen</h4>
        <ul>
          <li><a href="https://theairuntime.com">Newsletter</a></li>
          <li><a href="https://theairuntime.com/podcast">Podcast</a></li>
          <li><a href="https://www.youtube.com/@theairuntime">YouTube</a></li>
          <li><a href="/library">Library</a></li>
          <li><a href="/subscribe">Subscribe</a></li>
        </ul>
      </div>

      <div>
        <h4>Community</h4>
        <ul>
          <li><a href="/boston">Boston meetup</a></li>
          <li><a href="/speakers">Speakers</a></li>
          <li><a href="/field-lab">Field Lab</a></li>
          <li><a href="/speak">Speak at an event</a></li>
          <li><a href="/sponsors">Sponsor / partner</a></li>
        </ul>
      </div>

      <div>
        <h4>More</h4>
        <ul>
          <li><a href="/resources">Resources</a></li>
          <li><a href="/subscriber-only">Subscriber-only</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/faq">FAQ</a></li>
          <li><a href="mailto:info@theairuntime.com">Contact</a></li>
        </ul>
      </div>
    </div>

    <hr />

    <p class="small muted">© {new Date().getFullYear()} The AI Runtime · Built in Boston</p>
  </div>
</footer>

<style>
  .ftr {
    border-top: 1px solid var(--border);
    padding: 3.5rem 0 2.5rem;
    margin-top: 0;
    background: var(--bg-2);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr 1fr 1fr; }
    .brand { grid-column: 1 / -1; }
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .brand { grid-column: 1 / -1; }
  }
  h4 {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 0.75rem;
  }
  ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  ul a { color: var(--text-2); }
  ul a:hover { color: var(--text); text-decoration: none; }
  .small { font-size: 0.85rem; }
  .brand p { margin-top: 0.6rem; max-width: 22rem; }
</style>
