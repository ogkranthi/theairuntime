---
import type { CollectionEntry } from 'astro:content';

interface Props {
  speaker: CollectionEntry<'speakers'>;
  eventSlug?: string;
  showLink?: boolean;
}

const { speaker, eventSlug, showLink = true } = Astro.props;
const data = speaker.data;
const talk = eventSlug
  ? data.talks.find(
      (t) =>
        t.eventSlug === eventSlug ||
        eventSlug.endsWith(`/${t.eventSlug}`) ||
        t.eventSlug.endsWith(`/${eventSlug}`),
    )
  : data.talks[0];
const initials = data.name.split(' ').map((p) => p[0]).slice(0, 2).join('');
const social = data.social ?? {};
const links = [
  social.linkedin && { label: 'LinkedIn', href: social.linkedin },
  social.twitter && { label: 'X', href: social.twitter },
  social.github && { label: 'GitHub', href: social.github },
  social.website && { label: 'Site', href: social.website },
].filter(Boolean) as { label: string; href: string }[];
---
<article class="presenter">
  <div class="head">
    <div class="avatar">
      {data.photo ? <img src={data.photo} alt={data.name} loading="lazy" decoding="async" /> : <span>{initials}</span>}
    </div>
    <div class="who">
      <div class="name">{data.name}</div>
      <div class="role muted">{data.title} · {data.company}</div>
      {links.length > 0 && (
        <div class="social">
          {links.map((l) => <a href={l.href} target="_blank" rel="noopener">{l.label}</a>)}
        </div>
      )}
    </div>
  </div>

  {data.bio && <p class="bio dim">{data.bio}</p>}

  {talk && (
    <div class="talk">
      <span class="tag">Talk</span>
      <h3 class="title">{talk.title}</h3>
      <p class="dim">{talk.abstract}</p>
      {(talk.slidesUrl || talk.recordingUrl) && (
        <div class="materials">
          {talk.slidesUrl && <a class="material" href={talk.slidesUrl} target="_blank" rel="noopener">Slides ↗</a>}
          {talk.recordingUrl && <a class="material" href={talk.recordingUrl} target="_blank" rel="noopener">Recording ↗</a>}
        </div>
      )}
    </div>
  )}

  {showLink && <a class="more muted" href={`/speakers/${speaker.slug}`}>Speaker profile →</a>}
</article>

<style>
  .presenter {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 140ms ease, transform 140ms ease;
  }
  .presenter:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .head { display: flex; gap: 1.1rem; align-items: center; }
  .avatar {
    width: 88px; height: 88px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.4rem;
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }
  .name { font-family: var(--font-mono); font-weight: 700; font-size: 1.15rem; }
  .role { font-size: 0.92rem; margin-top: 0.1rem; }
  .social { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 0.45rem; }
  .social a { font-family: var(--font-mono); font-size: 0.78rem; color: var(--accent); }
  .bio { margin: 0; font-size: 0.98rem; }
  .tag {
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text-3);
  }
  .talk .title { margin: 0.35rem 0 0.4rem; font-size: 1.1rem; }
  .materials { display: flex; gap: 1rem; margin-top: 0.6rem; }
  .material { font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent); }
  .more { font-family: var(--font-mono); font-size: 0.85rem; }
  @media (max-width: 480px) {
    .head { flex-direction: column; align-items: flex-start; }
  }
</style>
