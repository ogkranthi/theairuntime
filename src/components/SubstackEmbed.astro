---
import SubscribeForm from './SubscribeForm.tsx';

interface Props {
  source?: string;
  variant?: 'card' | 'inline';
  headline?: string;
  subhead?: string;
  buttonLabel?: string;
}

const {
  source = 'site-subscribe',
  variant = 'card',
  headline = 'Get The AI Runtime in your inbox',
  subhead = 'Production lessons from engineers shipping AI. 1–2 pieces a week, no fluff.',
  buttonLabel = 'Subscribe',
} = Astro.props;
---
<div class={`subscribe ${variant}`}>
  {variant === 'card' && (
    <div class="copy">
      <h3>{headline}</h3>
      <p class="dim">{subhead}</p>
    </div>
  )}
  <div class="form-slot">
    <SubscribeForm client:load source={source} buttonLabel={buttonLabel} />
    <p class="muted small foot">
      Free. No spam. Unsubscribe in one click.
      <a href="https://theairuntime.com">See past issues →</a>
    </p>
  </div>
</div>

<style>
  .subscribe.card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 1.5rem;
    align-items: center;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
  }
  @media (max-width: 720px) {
    .subscribe.card { grid-template-columns: 1fr; }
  }
  .foot {
    font-size: 0.8rem;
    margin: 0.75rem 0 0;
    font-family: var(--font-mono);
  }
  .small { font-size: 0.85rem; }
</style>
