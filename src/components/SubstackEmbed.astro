---
import SubscribeForm from './SubscribeForm.tsx';

interface Props {
  source?: string;
  variant?: 'card' | 'inline';
  headline?: string;
  subhead?: string;
  buttonLabel?: string;
  successTitle?: string;
  successBody?: string;
  fallbackToPublication?: boolean;
  footer?: 'newsletter' | 'slack' | 'none';
  /** Conversion value bullets shown above the form (card variant). */
  bullets?: string[];
  /** Qualitative social proof line, e.g. "engineers from Microsoft, Wayfair, HBS, MIT". */
  proof?: string;
}

const {
  source = 'site-subscribe',
  variant = 'card',
  headline = 'Get The AI Runtime in your inbox',
  subhead = 'Production lessons from AI practitioners. New issues every week.',
  buttonLabel = 'Subscribe',
  successTitle,
  successBody,
  fallbackToPublication = false,
  footer = 'newsletter',
  bullets = [],
  proof = 'Read by AI practitioners at IBM, Amazon, Meta, Google, Nvidia, OpenAI, MIT, Harvard, and more for production learnings.',
} = Astro.props;
---
<div class={`subscribe ${variant}`}>
  {variant === 'card' && (
    <div class="copy">
      <h3>{headline}</h3>
      <p class="dim">{subhead}</p>
      {bullets.length > 0 && (
        <ul class="bullets">
          {bullets.map((b) => <li>{b}</li>)}
        </ul>
      )}
    </div>
  )}
  <div class="form-slot">
    <SubscribeForm
      client:load
      source={source}
      buttonLabel={buttonLabel}
      successTitle={successTitle}
      successBody={successBody}
      fallbackToPublication={fallbackToPublication}
    />
    {proof && <p class="proof muted small">{proof}</p>}
    {footer === 'newsletter' && (
      <p class="muted small foot">
        Free. No spam. Unsubscribe in one click.
        <a href="https://theairuntime.com">See past issues →</a>
      </p>
    )}
    {footer === 'slack' && (
      <p class="muted small foot">
        We'll email you when the Slack opens. No spam, ever.
      </p>
    )}
  </div>
</div>

<style>
  .subscribe.card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 1.5rem;
    align-items: center;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
  }
  @media (max-width: 720px) {
    .subscribe.card { grid-template-columns: 1fr; }
  }
  .bullets {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .bullets li {
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.92rem;
    color: var(--text-2);
  }
  .bullets li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .proof {
    font-size: 0.8rem;
    margin: 0.75rem 0 0;
  }
  .foot {
    font-size: 0.8rem;
    margin: 0.4rem 0 0;
    font-family: var(--font-mono);
  }
  .small { font-size: 0.85rem; }
</style>
