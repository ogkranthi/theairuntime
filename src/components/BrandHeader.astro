---
import BlinkLogo from './BlinkLogo.astro';
---
<header class="hdr">
  <div class="container row">
    <BlinkLogo size="sm" withTagline={false} />
    <nav>
      <a href="/boston">Events</a>
      <a href="/library">Library</a>
      <a href="https://theairuntime.com/subscribe" class="cta">Subscribe</a>
    </nav>
  </div>
</header>

<style>
  .hdr {
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.92rem;
  }
  nav a { color: var(--text-2); text-decoration: none; transition: color 120ms ease; }
  nav a:hover { color: var(--text); text-decoration: none; }
  nav .cta {
    color: #FFFFFF;
    background: var(--accent);
    padding: 0.4rem 0.95rem;
    border-radius: 999px;
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  nav .cta:hover { color: #FFFFFF; background: var(--accent-hover); }
  @media (max-width: 720px) {
    nav a:not(.cta) { display: none; }
  }
</style>
