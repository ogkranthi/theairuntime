---
interface Props {
  /** Section eyebrow. */
  eyebrow?: string;
  /** Heading. */
  title?: string;
  /** Supporting line under the heading. */
  lead?: string;
  /** Subject prefix so you can tell where the question came from. */
  subjectTag?: string;
}

const {
  eyebrow = 'Ask us directly',
  title = 'Have a specific question?',
  lead = 'Ask anything about shipping AI to production, the meetup, or the newsletter. It goes straight to our team.',
  subjectTag = 'Reader question',
} = Astro.props;

const inbox = 'info@theairuntime.com';
---
<div class="ask-q" data-inbox={inbox} data-subject-tag={subjectTag}>
  {eyebrow && <span class="tag">{eyebrow}</span>}
  {title && <h3>{title}</h3>}
  {lead && <p class="dim">{lead}</p>}

  <form class="aq-form">
    <label class="vh" for="aq-email">Your email</label>
    <input id="aq-email" class="aq-email" type="email" required placeholder="you@company.com (so we can reply)" />
    <label class="vh" for="aq-question">Your question</label>
    <textarea id="aq-question" class="aq-question" required rows="4" placeholder="What are you trying to figure out?"></textarea>
    <div class="aq-row">
      <button type="submit" class="btn">Send your question</button>
      <span class="aq-hint muted small">Opens your email app, sends to {inbox}.</span>
    </div>
    <p class="aq-fallback muted small">
      Prefer to email directly? <a href={`mailto:${inbox}`}>{inbox}</a>
    </p>
  </form>
</div>

<script>
  // Compose a pre-filled email to the inbox. No backend: this opens the
  // visitor's own mail client, so their address becomes the reply-to and the
  // question lands in our inbox.
  document.querySelectorAll('.ask-q').forEach((root) => {
    const el = root as HTMLElement;
    const inbox = el.dataset.inbox || 'info@theairuntime.com';
    const tag = el.dataset.subjectTag || 'Reader question';
    const form = el.querySelector('.aq-form') as HTMLFormElement | null;
    const emailInput = el.querySelector('.aq-email') as HTMLInputElement | null;
    const questionInput = el.querySelector('.aq-question') as HTMLTextAreaElement | null;
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const question = (questionInput?.value || '').trim();
      const from = (emailInput?.value || '').trim();
      if (question.length < 5) return;
      const subject = `${tag}: ${question.slice(0, 60)}${question.length > 60 ? '…' : ''}`;
      const body =
        `${question}\n\n` +
        `---\n` +
        `From: ${from || '(no email provided)'}\n` +
        `Page: ${location.href}`;
      const href = `mailto:${inbox}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = href;
    });
  });
</script>

<style>
  .ask-q { max-width: 42rem; }
  .ask-q h3 { margin: 0.6rem 0 0.4rem; }
  .aq-form { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 1rem; }
  .aq-email, .aq-question {
    width: 100%;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
  .aq-question { resize: vertical; min-height: 5.5rem; }
  .aq-email:focus, .aq-question:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  .aq-row { display: flex; gap: 0.85rem; align-items: center; flex-wrap: wrap; }
  .aq-hint { font-family: var(--font-mono); }
  .aq-fallback { margin: 0.25rem 0 0; }
  .small { font-size: 0.85rem; }
  .vh {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
</style>
