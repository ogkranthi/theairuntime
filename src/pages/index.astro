---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SubstackEmbed from '../components/SubstackEmbed.astro';
import Blink from '../components/Blink.astro';
import RecapGallery from '../components/RecapGallery.astro';
import CredibilityStrip from '../components/CredibilityStrip.astro';
import StatBand from '../components/StatBand.astro';
import { getCollection } from 'astro:content';
import { fetchSubstackPosts } from '../lib/substack';

const posts = await fetchSubstackPosts(4);
const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

// Most recent past Boston event that has photos, for the homepage energy band.
const bostonEvents = await getCollection('events', (e) => e.slug.startsWith('boston/'));
const lastRecap = bostonEvents
  .filter((e) => e.data.status === 'past' && e.data.recapPhotos.length > 0)
  .sort((a, b) => +b.data.date - +a.data.date)[0];
const lastRecapSlug = lastRecap?.slug.replace(/^boston\//, '');
---
<BaseLayout
  title="The AI Runtime"
  description="The AI Runtime is a community of AI practitioners. A weekly newsletter on production AI, monthly in-person meetups in Boston, and hands-on labs. Evals, agents, inference, reliability, cost."
>
  <section class="hero">
    <div class="container">
      <div class="grid">
        <div class="copy">
          <span class="tag">The AI Runtime</span>
          <h1>Production lessons from AI practitioners</h1>
          <p class="lede dim">
            The AI Runtime is a community of AI practitioners. Read the weekly newsletter, come to
            the Boston meetups, and become part of the <a href="/field-lab">Field Lab</a>. It starts
            with a free weekly issue of production lessons, the kind you'd forward to your team.
          </p>
          <div class="sub">
            <SubstackEmbed
              source="home-hero"
              variant="inline"
              buttonLabel="Subscribe free"
            />
          </div>
        </div>
        <div class="art"><Blink size={150} showMotion={true} showCheeks={true} /></div>
      </div>
    </div>
  </section>

  <CredibilityStrip />

  <StatBand />

  <Section eyebrow="What we do" title="Read, meet, and build" flush>
    <ul class="arms">
      <li>
        <span class="arm-k">Read</span>
        <h3>The weekly newsletter</h3>
        <p class="dim">Production lessons on Vertical AI Agents, Model Reliability Engineering, and lessons from the trenches of shipping AI. Free, every week.</p>
        <a class="arm-link" href="https://theairuntime.com">Read the newsletter →</a>
      </li>
      <li>
        <span class="arm-k">Meet</span>
        <h3>The Boston meetup</h3>
        <p class="dim">A monthly meetup in Cambridge. Two practitioner talks a night, real production stories, and the people who ship.</p>
        <a class="arm-link" href="/boston">See the next event →</a>
      </li>
      <li>
        <span class="arm-k">Build</span>
        <h3>The Field Lab</h3>
        <p class="dim">A library of production-shaped AI problems and a build pilot, so practitioners work on real problems instead of demos.</p>
        <a class="arm-link" href="/field-lab">Explore the Field Lab →</a>
      </li>
    </ul>
  </Section>

  {posts.length > 0 && (
    <Section eyebrow="Latest issues" title="Fresh from the newsletter">
      <ul class="issues">
        {posts.map((p) => (
          <li>
            <a href={p.url} target="_blank" rel="noopener">
              <span class="date muted">{dateFmt.format(p.publishedAt)}</span>
              <span class="t">{p.title}</span>
              <span class="sum dim">{p.summary}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="more"><a href="https://theairuntime.com">Read every issue at theairuntime.com →</a></p>
    </Section>
  )}

  <Section eyebrow="In person" title="The AI Runtime Boston" narrow>
    <p class="dim">
      A monthly meetup in Cambridge for practitioners shipping AI to production. Two practitioner
      talks a night, real production stories.
    </p>
    <p>
      <a class="btn" href="/boston">See the next event →</a>
      <a class="btn btn-ghost" href="/speakers">Past speakers</a>
    </p>
  </Section>

  {lastRecap && (
    <Section eyebrow="In the room" title="From the last meetup">
      <p class="dim wide">
        A full room in Cambridge for {lastRecap.data.title}. Two production talks, real questions,
        people who ship. The next one is coming.
      </p>
      <RecapGallery photos={lastRecap.data.recapPhotos} />
      <p class="recap-links">
        <a class="btn btn-ghost" href={`/boston/${lastRecapSlug}#recap`}>See the full recap →</a>
        <a class="btn" href="/boston">Come to the next one</a>
      </p>
    </Section>
  )}

  <Section eyebrow="The Field Lab" title="Build on real problems, not demos" narrow>
    <p class="dim">
      The Field Lab is where builders work on real, production-shaped AI problems. A library of
      buildable briefs, a build pilot, and the free tools to start.
    </p>
    <p>
      <a class="btn" href="/field-lab">Explore the Field Lab →</a>
      <a class="btn btn-ghost" href="/briefs">Field Briefs</a>
    </p>
  </Section>

  <Section eyebrow="Free resource" title="The AI Runtime Field Guide" narrow>
    <p class="dim">
      A guided reading path through The AI Runtime for AI practitioners. The essential reads on AI
      engineering, Model Reliability Engineering, and vertical agents, in the order that builds real
      production intuition. Free, no email required.
    </p>
    <p>
      <a class="btn" href="/resources/the-ai-runtime-field-guide.pdf" download>Download the PDF →</a>
      <a class="btn btn-ghost" href="/library">Reading library</a>
    </p>
  </Section>

  <Section eyebrow="Subscribe" title="Get it in your inbox" narrow>
    <p class="dim">
      Free, weekly, anti-hype. Production lessons from practitioners, plus the next Boston event
      before the public drop.
    </p>
    <SubstackEmbed
      source="home-footer"
      headline="Get The AI Runtime in your inbox"
      subhead="One free issue a week. The operational layer where AI actually runs."
      buttonLabel="Subscribe free"
      bullets={[
        'Evals, agents, inference, reliability, cost',
        'Specific and sourced, the kind of piece you forward to your team',
        'The next Boston meetup before the public Luma drop',
      ]}
    />
  </Section>
</BaseLayout>

<style>
  .wide { max-width: 42rem; }
  .recap-links { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .arms {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 760px) { .arms { grid-template-columns: 1fr; } }
  .arms li {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 140ms ease;
  }
  .arms li:hover { border-color: var(--accent); }
  .arm-k {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
  }
  .arms h3 { margin: 0.5rem 0 0.5rem; font-size: 1.15rem; }
  .arms p { font-size: 0.95rem; }
  .arm-link {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .hero {
    padding: 4.5rem 0 4rem;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(ellipse at top right, rgba(251, 146, 60, 0.10), transparent 55%),
      var(--bg);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
    .art { order: -1; }
  }
  h1 { margin: 0.7rem 0 0; }
  .lede { font-size: 1.15rem; max-width: 36rem; margin-top: 1rem; }
  .sub { margin-top: 1.75rem; max-width: 32rem; }
  .art { display: flex; justify-content: center; }

  .issues { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .issues a {
    display: grid;
    grid-template-columns: 110px 1fr;
    grid-template-areas: 'date title' 'date sum';
    gap: 0.1rem 1.25rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    text-decoration: none;
  }
  .issues a:hover { border-color: var(--accent); }
  .issues .date { grid-area: date; font-family: var(--font-mono); font-size: 0.8rem; padding-top: 0.15rem; }
  .issues .t { grid-area: title; font-family: var(--font-mono); font-weight: 700; }
  .issues .sum { grid-area: sum; font-size: 0.92rem; }
  @media (max-width: 560px) {
    .issues a { grid-template-columns: 1fr; grid-template-areas: 'date' 'title' 'sum'; gap: 0.25rem; }
  }
  .more { margin-top: 1.25rem; font-family: var(--font-mono); font-size: 0.9rem; }
</style>
