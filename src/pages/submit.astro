---
import LabLayout from '../layouts/LabLayout.astro';
import { SUBMIT_FORM_URL, CONTACT_EMAIL } from '../lib/lab-links';
---
<LabLayout
  title="Submit a problem · The AI Runtime Field Lab"
  description="Have a production-shaped reliability problem in an AI system? Submit it as a candidate Field Brief."
>
  <section class="hero">
    <div class="lab-container">
      <p class="mono-label eyebrow">Field Lab · Submit</p>
      <h1>Submit a problem</h1>
      <p class="sub">
        A good Brief is a real, production-shaped reliability problem in an AI system, with a clear line
        for what would count as solved. Send yours and it may become a Field Brief that a Lab builds
        against.
      </p>
      <p class="fine">Submitting is not a commitment on either side, and creates no contractor or hiring relationship.</p>
    </div>
  </section>

  <section class="sec">
    <div class="lab-container">
      {SUBMIT_FORM_URL ? (
        <div class="embed">
          <iframe
            class="airtable-embed"
            src={SUBMIT_FORM_URL}
            title="Submit a problem to the Field Lab"
            loading="lazy"
            width="100%"
            height="720"
          ></iframe>
        </div>
      ) : (
        <p class="dim">
          The submission form is being set up. In the meantime, email
          {' '}<a href={`mailto:${CONTACT_EMAIL}?subject=Field%20Lab%20problem%20submission`}>{CONTACT_EMAIL}</a>.
        </p>
      )}
    </div>
  </section>
</LabLayout>

<style>
  .hero { padding: 4rem 0 2rem; }
  .eyebrow { margin: 0 0 1rem; color: var(--accent); }
  .sub { max-width: 42rem; margin: 0.9rem 0 1rem; font-size: 1.15rem; color: var(--text-2); }
  .fine { margin: 0; font-size: 0.9rem; color: var(--text-3); max-width: 42rem; }
  .sec { padding: 1rem 0 3rem; }
  .embed {
    max-width: 46rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .embed iframe { display: block; background: transparent; border: 0; }
  .dim { color: var(--text-2); }
  .dim a { color: var(--accent); }
</style>
