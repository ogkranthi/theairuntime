---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

// The "run an event" intake is an embedded Airtable form. Swap this one URL to
// point at a different form; Airtable handles storage and emails a copy of each
// submission to the team (a setting on the form itself, no code needed).
const FORM_URL = 'https://airtable.com/embed/appHnMPcsBu6XTApu/pagDRFOi4sD8P6V8h/form';
---
<BaseLayout
  title="Run an event with The AI Runtime"
  description="Want to run an AI Runtime event in your city? Bring a room or an audience and we bring the program. Tell us what you have in mind."
>
  <Section eyebrow="Run an event" title="Run an AI Runtime event in your city">
    <p class="lead dim">
      The AI Runtime runs evenings for people building, shipping, and scaling with AI: a hands-on
      session, real production patterns, and time to meet other practitioners. If you can bring a room
      or an audience, we can bring the program.
    </p>
    <ul class="split">
      <li>
        <span class="k">We bring</span>
        <p class="dim">The program, speakers, a hands-on workshop, and the audience from our community and newsletter.</p>
      </li>
      <li>
        <span class="k">You bring</span>
        <p class="dim">A room for the evening, or a city and a crowd that wants one. A co-host, venue, or local organizer all work.</p>
      </li>
    </ul>
  </Section>

  <Section eyebrow="Get started" title="Tell us what you have in mind">
    <p class="dim wide">
      Share your city, a venue if you have one, and what you are thinking. We reply within a few days.
      Reaching out is not a commitment on either side.
    </p>
    <div class="embed">
      <iframe
        class="airtable-embed"
        src={FORM_URL}
        title="Run an event with The AI Runtime intake form"
        loading="lazy"
        width="100%"
        height="720"
      ></iframe>
    </div>
  </Section>
</BaseLayout>

<style>
  .lead { max-width: 42rem; }
  .wide { max-width: 42rem; }

  .split {
    list-style: none;
    padding: 0;
    margin: 1.75rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .split li {
    padding: 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .split .k {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .split p { margin: 0.5rem 0 0; }

  .embed {
    margin-top: 1.5rem;
    max-width: 46rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .embed iframe {
    display: block;
    background: transparent;
    border: 0;
  }
</style>
