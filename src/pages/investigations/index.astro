---
import { getCollection } from "astro:content";
import LabLayout from "../../layouts/LabLayout.astro";
import InvestigationCard from "../../components/lab/InvestigationCard.astro";

const investigations = (await getCollection("investigations")).sort(
  (a, b) => b.data.started.valueOf() - a.data.started.valueOf(),
);

const title = "The AI Runtime Lab";
const description =
  "The work a forward-deployed engineer does, in public. Embed in a real customer-shaped problem, scope it, ship the smallest system that holds a reliability bar in production, and publish what broke. Production systems, not slides. Updated weekly.";

const steps = [
  {
    k: "Scope the real problem",
    v: "Start from a real customer-shaped problem and find the problem behind the stated ask, then size it.",
  },
  {
    k: "Set the reliability bar",
    v: "Fix a hard target up front and freeze it, so the result is pass or fail, not a demo that looks good.",
  },
  {
    k: "Ship the smallest system",
    v: "Build the least that can hold the bar in production, with evals and observability before any rollout.",
  },
  {
    k: "Generalize",
    v: "Spot what recurs and turn it into a repeatable method, the part of FDE work that compounds.",
  },
];
---

<LabLayout title={title} description={description}>
  <section class="hero">
    <div class="lab-container">
      <p class="hero__eyebrow mono-label">The AI Runtime Lab</p>
      <p class="hero__lead">
        The work a forward-deployed engineer does, in public. Embed in a real
        customer-shaped problem, scope it, ship the smallest system that holds a
        reliability bar, and publish what broke.
      </p>
      <p class="hero__sub">
        Production systems, not slides. Out-of-the-box rarely survives first
        contact with a real constraint, so each field report builds and
        measures until the bar holds, and updates weekly as the work happens.
      </p>
    </div>
  </section>

  <section class="how">
    <div class="lab-container">
      <h2 class="how__heading mono-label">How the Lab works</h2>
      <ol class="how__grid">
        {steps.map((s, i) => (
          <li class="how__step">
            <span class="how__num">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="how__k">{s.k}</h3>
            <p class="how__v">{s.v}</p>
          </li>
        ))}
      </ol>
      <p class="how__note">
        The same loop that forward-deployed engineers run inside one customer:
        spot what recurs across problems and generalize it. Each field report
        is built to be replicated, the rubric, the eval harness, and the code
        are portable to the next problem.
      </p>
    </div>
  </section>

  <section class="feed">
    <div class="lab-container">
      <h2 class="feed__heading mono-label">Field Reports</h2>
      <ul class="feed__list">
        {investigations.map((entry) => (
          <li><InvestigationCard entry={entry} /></li>
        ))}
      </ul>
    </div>
  </section>
</LabLayout>

<style>
  .hero { padding: 4.5rem 0 3rem; border-bottom: 1px solid var(--border); }
  .hero__eyebrow { margin: 0 0 1.2rem; color: var(--accent); }
  .hero__lead {
    max-width: 46rem;
    font-size: clamp(1.4rem, 3.4vw, 2.1rem);
    line-height: 1.35;
    color: var(--text);
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .hero__sub {
    max-width: 42rem;
    margin: 1.4rem 0 0;
    color: var(--text-2);
    font-size: 1.05rem;
  }

  .how { padding: 3rem 0; border-bottom: 1px solid var(--border); }
  .how__heading { margin: 0 0 1.8rem; }
  .how__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  }
  .how__step {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-2);
    padding: 1.3rem 1.4rem;
  }
  .how__num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
  }
  .how__k { margin: 0.5rem 0 0.4rem; font-size: 1rem; }
  .how__v { margin: 0; font-size: 0.95rem; color: var(--text-2); }
  .how__note {
    max-width: 42rem;
    margin: 1.8rem 0 0;
    color: var(--text-2);
  }

  .feed { padding: 3rem 0 1rem; }
  .feed__heading { margin: 0 0 1.5rem; }
  .feed__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }
</style>
