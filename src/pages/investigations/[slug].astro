---
import { getCollection, render } from "astro:content";
import LabLayout from "../../layouts/LabLayout.astro";
import StatusPill from "../../components/lab/StatusPill.astro";
import StageTimeline from "../../components/lab/StageTimeline.astro";
import EvidenceArtifacts from "../../components/lab/EvidenceArtifacts.astro";
import Prose from "../../components/lab/Prose.astro";

// URL comes from the frontmatter slug, not the filename, so renaming the
// content file does not change the route.
export async function getStaticPaths() {
  const entries = await getCollection("investigations");
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const updated = d.updated.toISOString().slice(0, 10);

const title = `${d.title} | The AI Runtime Lab`;
---

<LabLayout title={title} description={d.summary} ogType="article">
  <article class="lab-container detail">
    <header class="detail__head reading">
      <div class="detail__top">
        <span class="mono-label">Investigation {d.id}</span>
        <StatusPill status={d.status} />
      </div>
      <h1>{d.title}</h1>
      <p class="detail__question">{d.question}</p>
      <dl class="detail__dates">
        <div>
          <dt class="mono-label">Updated</dt>
          <dd><time datetime={updated}>{updated}</time></dd>
        </div>
        {d.pillar && (
          <div>
            <dt class="mono-label">Pillar</dt>
            <dd>{d.pillar}</dd>
          </div>
        )}
      </dl>
    </header>

    <section class="progress-section reading" aria-labelledby="progress-heading">
      <h2 id="progress-heading" class="mono-label">Progress</h2>
      <StageTimeline stages={d.stages} />
    </section>

    <section class="problem reading" aria-labelledby="problem-heading">
      <h2 id="problem-heading">Problem and scope</h2>
      <dl class="problem__grid">
        {d.industry && (
          <div>
            <dt class="mono-label">Industry</dt>
            <dd>{d.industry}</dd>
          </div>
        )}
        <div>
          <dt class="mono-label">Customer</dt>
          <dd>{d.customer}</dd>
        </div>
        <div>
          <dt class="mono-label">The ask</dt>
          <dd>{d.problem}</dd>
        </div>
        <div>
          <dt class="mono-label">The engineering question</dt>
          <dd class="problem__question">{d.question}</dd>
        </div>
        {d.bar && (
          <div>
            <dt class="mono-label">Reliability bar</dt>
            <dd>{d.bar}</dd>
          </div>
        )}
      </dl>

      {(d.inScope.length > 0 || d.outScope.length > 0) && (
        <div class="scope">
          {d.inScope.length > 0 && (
            <div class="scope__col">
              <p class="mono-label">In scope</p>
              <ul class="scope__list scope__list--in">
                {d.inScope.map((s) => <li>{s}</li>)}
              </ul>
            </div>
          )}
          {d.outScope.length > 0 && (
            <div class="scope__col">
              <p class="mono-label">Out of scope</p>
              <ul class="scope__list scope__list--out">
                {d.outScope.map((s) => <li>{s}</li>)}
              </ul>
            </div>
          )}
        </div>
      )}
    </section>

    <div class="reading">
      <EvidenceArtifacts
        repo={d.repo}
        evalUrl={d.evalUrl}
        datasetUrl={d.datasetUrl}
        reportUrl={d.reportUrl}
      />
    </div>

    <Prose>
      <Content />
    </Prose>

    {d.tags.length > 0 && (
      <footer class="detail__footer reading">
        <h2 class="mono-label">Tags</h2>
        <ul class="detail__tags">
          {d.tags.map((t) => <li class="tag">{t}</li>)}
        </ul>
      </footer>
    )}
  </article>
</LabLayout>

<style>
  .detail { padding: 3rem 0 1rem; }
  .detail__head { margin-bottom: 2.5rem; }
  .detail__top { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.2rem; }
  .detail__head h1 { margin: 0 0 0.8rem; }

  /* The question is prominent beneath the title. */
  .detail__question {
    font-family: var(--font-mono);
    font-size: clamp(1.1rem, 2.4vw, 1.4rem);
    line-height: 1.35;
    color: var(--accent);
    margin: 0 0 1.6rem;
  }

  .detail__dates { display: flex; flex-wrap: wrap; gap: 1rem 2.5rem; margin: 0; }
  .detail__dates dt { margin-bottom: 0.2rem; }
  .detail__dates dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--text-2);
  }

  .progress-section { margin: 0 0 2.5rem; }
  .progress-section h2 { margin: 0 0 1.4rem; }

  /* Lead-with-the-problem block, visually prominent. */
  .problem {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 1.6rem 1.8rem;
    margin: 0 0 0.5rem;
  }
  .problem h2 { font-size: 1.1rem; margin: 0 0 1.2rem; }
  .problem__grid { display: grid; gap: 1.1rem; margin: 0; }
  .problem__grid dt { margin-bottom: 0.25rem; }
  .problem__grid dd { margin: 0; color: var(--text); }
  .problem__question { font-family: var(--font-mono); color: var(--accent) !important; }

  /* In scope / out of scope, two columns under the grid. */
  .scope {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2rem;
    margin-top: 1.6rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--border);
  }
  .scope__col .mono-label { display: block; margin-bottom: 0.6rem; }
  .scope__list { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.4rem; }
  .scope__list li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.95rem;
    color: var(--text-2);
  }
  .scope__list li::before { position: absolute; left: 0; top: -0.02em; }
  .scope__list--in li::before { content: "+"; color: var(--accent); font-weight: 700; }
  .scope__list--out li::before { content: "-"; color: var(--text-3); font-weight: 700; }
  @media (max-width: 560px) { .scope { grid-template-columns: 1fr; } }

  .detail__footer { margin-top: 3rem; }
  .detail__footer h2 { margin-bottom: 0.8rem; }
  .detail__tags { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 0; padding: 0; }
</style>
