---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProblemCard from '../../components/ProblemCard.astro';
import { intakeUrl, builderUrl, HERO_BRIEF_SLUG } from '../../lib/field-briefs';

const all = await getCollection('problems');

// The hero brief leads the library. It is pinned by id, not by provenance, so
// any standout brief can take the slot.
const heroBrief = all.find((p) => p.id === HERO_BRIEF_SLUG);

// Newest failure-derived brief takes the failure feature below the grid.
const failureDerived = all
  .filter((p) => p.data.provenance === 'failure-derived')
  .sort((a, b) => (b.data.month ?? '').localeCompare(a.data.month ?? ''));
const featured = failureDerived[0];

// Open briefs that share the failure brief's family. The hero brief is shown on
// its own above, so keep it out of this list.
const familyMatched = featured?.data.failure_family
  ? all.filter(
      (p) =>
        p.id !== featured.id &&
        p.id !== heroBrief?.id &&
        p.data.status === 'Open' &&
        p.data.failure_family === featured.data.failure_family,
    )
  : [];

// The grid shows everything except the hero brief and the failure feature brief.
const statusOrder: Record<string, number> = { Featured: 0, Open: 1, Claimed: 2, Shipped: 3 };
const grid = all
  .filter((p) => p.id !== featured?.id && p.id !== heroBrief?.id)
  .sort((a, b) => {
    const s = (statusOrder[a.data.status] ?? 9) - (statusOrder[b.data.status] ?? 9);
    return s !== 0 ? s : a.data.title.localeCompare(b.data.title);
  });

const distinct = (key: string) =>
  [...new Set(all.map((p) => (p.data as any)[key]).filter(Boolean))].sort();
const verticals = distinct('vertical');
const difficulties = ['Starter', 'Intermediate', 'Advanced'].filter((d) =>
  all.some((p) => p.data.difficulty === d),
);
const buildTypes = distinct('build_type');
const statuses = ['Open', 'Claimed', 'Shipped', 'Featured'].filter((s) =>
  all.some((p) => p.data.status === s),
);

const metaDesc =
  'A public library of sanitized, production-shaped AI problems scoped for serious builders. Merchant operations copilots, support triage agents, sales engineer copilots, cost and latency routers, and reality-gap eval harnesses, each a buildable brief with a stated reliability bar.';
---
<BaseLayout
  title="Field Briefs: Real AI Problems for Serious Builders | The AI Runtime Field Lab"
  description={metaDesc}
  noSubBar
  chrome="lab"
>
  <div class="fl">
    <!-- Hero -->
    <section class="hero">
      <div class="wrap">
        <p class="kicker"><a href="/field-lab">The AI Runtime Field Lab</a></p>
        <h1>Real AI problems, scoped for serious builders.</h1>
        <p class="sub">
          A public library of sanitized AI workflow problems from startups and operators, turned into
          buildable, testable briefs with a stated reliability bar. Production-shaped problems, not
          random demos. Not a job board, a bootcamp, or a recruiting agency.
        </p>
        <div class="cta-row">
          <a class="btn solid" href={intakeUrl()} target="_blank" rel="noopener">Submit a problem</a>
          <a class="btn ghost" href="#problems">Explore problems</a>
        </div>
      </div>
    </section>

    {heroBrief && (
      <section class="band featured-brief">
        <div class="wrap">
          <p class="eyebrow">Featured brief</p>
          <h2>{heroBrief.data.title}</h2>
          <p class="hb-line">{heroBrief.data.one_line}</p>
          <p class="hb-meta">
            {heroBrief.data.vertical} · {heroBrief.data.difficulty} · {heroBrief.data.build_type} · Reliability {heroBrief.data.run_level}
          </p>
          {heroBrief.data.reliability_focus?.length > 0 && (
            <ul class="hb-focus">
              {heroBrief.data.reliability_focus.map((f: string) => <li>{f}</li>)}
            </ul>
          )}
          <div class="cta-row">
            <a class="btn solid" href={`/briefs/${heroBrief.id}`}>Read the full brief →</a>
            <a class="btn ghost" href={builderUrl()} target="_blank" rel="noopener">Build this brief</a>
          </div>
        </div>
      </section>
    )}

    <!-- Problem library: the centerpiece, kept near the top -->
    <section id="problems" class="band">
      <div class="wrap">
        <h2>The problem library</h2>
        <form class="filters" aria-label="Filter problems">
          <label>Vertical
            <select data-filter="vertical">
              <option value="">All</option>
              {verticals.map((v) => <option value={v}>{v}</option>)}
            </select>
          </label>
          <label>Difficulty
            <select data-filter="difficulty">
              <option value="">All</option>
              {difficulties.map((d) => <option value={d}>{d}</option>)}
            </select>
          </label>
          <label>Build type
            <select data-filter="build-type">
              <option value="">All</option>
              {buildTypes.map((b) => <option value={b}>{b}</option>)}
            </select>
          </label>
          <label>Status
            <select data-filter="status">
              <option value="">All</option>
              {statuses.map((s) => <option value={s}>{s}</option>)}
            </select>
          </label>
          <label>Provenance
            <select data-filter="provenance">
              <option value="">All</option>
              <option value="curated">Curated</option>
              <option value="failure-derived">Failure-derived</option>
            </select>
          </label>
        </form>
        <p class="count" data-count aria-live="polite"></p>
        <div class="cards" data-grid>
          {grid.map((p) => <ProblemCard id={p.id} data={p.data} />)}
        </div>
        <p class="empty" data-empty hidden>No briefs match those filters. Clear a filter to see more.</p>
      </div>
    </section>

    {featured && (
      <section class="band featured-failure">
        <div class="wrap">
          <p class="eyebrow">This month's failure brief</p>
          <h2>The failure behind this brief</h2>
          <div class="failure-grid">
            <div class="story">
              <div class="story-block">
                <span class="lbl">What happened</span>
                <p>{featured.data.failure_story?.what_happened}</p>
              </div>
              <div class="story-block">
                <span class="lbl">Root cause read</span>
                <p>{featured.data.failure_story?.root_cause_read}</p>
              </div>
              <div class="story-block">
                <span class="lbl">Engineering lesson</span>
                <p>{featured.data.failure_story?.engineering_lesson}</p>
              </div>
              {featured.data.sources?.length > 0 && (
                <p class="sources">
                  <span class="lbl">Sources</span>
                  {featured.data.sources.map((s: string, i: number) => (
                    <a href={s} target="_blank" rel="noopener">Source {i + 1}</a>
                  ))}
                </p>
              )}
              {featured.data.primary_source_note && (
                <p class="psn">Editorial note: {featured.data.primary_source_note}</p>
              )}
            </div>
            <div class="brief-slot">
              <p class="build-line">This month's build: close the gap that caused it.</p>
              <ProblemCard id={featured.id} data={featured.data} />
            </div>
          </div>

          {familyMatched.length > 0 && (
            <div class="family-open">
              <h3>Open briefs in this failure family</h3>
              <div class="cards">
                {familyMatched.map((p) => <ProblemCard id={p.id} data={p.data} />)}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Single submit CTA -->
    <section class="band invert">
      <div class="wrap narrow">
        <h2>Have a real AI workflow problem? Submit it.</h2>
        <p>
          A good problem is specific, painful, buildable with sample or synthetic data, and evaluable
          without production access. Selected problems may be rewritten into public briefs.
        </p>
        <a class="btn solid" href={intakeUrl()} target="_blank" rel="noopener">Submit a problem</a>
      </div>
    </section>

    <!-- Single disclaimer -->
    <section class="band footer-disclaimer">
      <div class="wrap narrow">
        <p>
          Field Briefs is an educational and community resource. Submitting creates no contractor,
          delivery, or hiring relationship. Problem contributors do not receive guaranteed prototypes,
          and builders do not receive guaranteed mentorship, review, publication, referrals, jobs,
          funding, credits, or company access. Selected problems and submissions may be featured at The
          AI Runtime's discretion.
        </p>
      </div>
    </section>
  </div>

  <script>
    // Progressive enhancement: the grid is fully visible without JS. Filters
    // narrow it by matching every active select against each card's data-*.
    const form = document.querySelector('.filters');
    const grid = document.querySelector('[data-grid]');
    const empty = document.querySelector('[data-empty]') as HTMLElement | null;
    const count = document.querySelector('[data-count]') as HTMLElement | null;
    const toCamel = (s: string) => s.replace(/-([a-z])/g, (_m, c) => c.toUpperCase());
    if (form && grid) {
      const cards = Array.from(grid.querySelectorAll('.brief-card')) as HTMLElement[];
      const selects = Array.from(form.querySelectorAll('select')) as HTMLSelectElement[];
      const apply = () => {
        let shown = 0;
        cards.forEach((card) => {
          const match = selects.every((sel) => {
            const want = sel.value;
            if (!want) return true;
            return card.dataset[toCamel(sel.dataset.filter || '')] === want;
          });
          card.hidden = !match;
          if (match) shown += 1;
        });
        if (empty) empty.hidden = shown !== 0;
        if (count) count.textContent = `${shown} ${shown === 1 ? 'brief' : 'briefs'}`;
      };
      selects.forEach((sel) => sel.addEventListener('change', apply));
      apply();
    }
  </script>

  <style is:global>
    .fl {
      --fl-ink: #161616;
      --fl-body: #3a352e;
      --fl-muted: #6f6a61;
      --fl-faint: #8a857c;
      --fl-paper: #fdfcfa;
      --fl-surface: #fbfaf7;
      --fl-chip: #f1ede4;
      --fl-border: #e6e1d6;
      --fl-accent: #e8852b;
      --fl-accent-hover: #f5a04f;
      --fl-dark-text: #ece6dc;
      --fl-serif: Georgia, 'Times New Roman', serif;
      --fl-sans: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
      background: var(--fl-paper);
      color: var(--fl-body);
      font-family: var(--fl-sans);
    }
    .fl .wrap { max-width: 64rem; margin: 0 auto; padding: 0 1.5rem; }
    .fl .wrap.narrow { max-width: 46rem; }
    .fl h1, .fl h2, .fl h3 { font-family: var(--fl-serif); color: var(--fl-ink); letter-spacing: -0.01em; }
    .fl h2 { font-size: clamp(1.5rem, 3vw, 2rem); margin: 0 0 1rem; }
    .fl p { line-height: 1.7; }

    .fl .hero { background: var(--fl-paper); padding: 4.5rem 0 3rem; border-bottom: 1px solid var(--fl-border); }
    .fl .kicker {
      font-size: 0.76rem; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--fl-accent); font-weight: 600; margin: 0 0 0.85rem;
    }
    .fl .kicker a { color: inherit; text-decoration: none; }
    .fl .kicker a:hover { text-decoration: underline; }
    .fl .hero h1 { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.12; margin: 0 0 1rem; max-width: 20ch; }
    .fl .hero .sub { font-size: 1.15rem; color: var(--fl-body); max-width: 46rem; margin: 0 0 1.75rem; }
    .fl .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }

    .fl .btn {
      display: inline-block; padding: 0.8rem 1.5rem; border-radius: 8px;
      font-family: var(--fl-sans); font-weight: 700; font-size: 0.95rem; cursor: pointer;
      text-decoration: none; border: 1px solid var(--fl-ink);
      transition: background 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .fl .btn.solid { background: var(--fl-ink); color: var(--fl-paper); }
    .fl .btn.solid:hover { background: var(--fl-accent); border-color: var(--fl-accent); color: var(--fl-ink); }
    .fl .btn.ghost { background: transparent; color: var(--fl-ink); }
    .fl .btn.ghost:hover { border-color: var(--fl-accent); color: var(--fl-accent); }
    .fl .btn:focus-visible { outline: 2px solid var(--fl-accent); outline-offset: 3px; }

    .fl .band { padding: 3.5rem 0; border-bottom: 1px solid var(--fl-border); }
    .fl .band.alt { background: var(--fl-surface); }
    .fl .band.invert { background: var(--fl-ink); }
    .fl .band.invert h2 { color: #fefcf8; }
    .fl .band.invert p { color: var(--fl-dark-text); }
    .fl .band.invert .btn.solid { background: var(--fl-accent); border-color: var(--fl-accent); color: var(--fl-ink); }
    .fl .band.invert .btn.solid:hover { background: var(--fl-accent-hover); border-color: var(--fl-accent-hover); }

    .fl .featured-brief { background: var(--fl-surface); }
    .fl .featured-brief h2 { font-size: clamp(1.7rem, 4vw, 2.4rem); margin: 0.5rem 0 0.75rem; max-width: 24ch; }
    .fl .hb-line { font-family: var(--fl-serif); font-size: 1.15rem; color: var(--fl-ink); max-width: 48rem; margin: 0 0 0.75rem; }
    .fl .hb-meta { font-size: 0.82rem; color: var(--fl-faint); margin: 0 0 1.1rem; }
    .fl .hb-focus { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .fl .hb-focus li { font-size: 0.8rem; padding: 0.35rem 0.7rem; background: var(--fl-chip); border-radius: 999px; color: var(--fl-body); }

    .fl .featured-failure { background: var(--fl-surface); }
    .fl .eyebrow { font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fl-accent); font-weight: 600; margin: 0 0 0.5rem; }
    .fl .failure-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 2rem; align-items: start; }
    .fl .story-block { margin-bottom: 1.1rem; }
    .fl .lbl { display: block; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--fl-accent); margin-bottom: 0.25rem; }
    .fl .story-block p { margin: 0; font-size: 0.96rem; color: var(--fl-body); }
    .fl .sources { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: baseline; margin: 0.5rem 0 0; }
    .fl .sources a { color: var(--fl-accent); font-size: 0.88rem; }
    .fl .psn { font-size: 0.82rem; color: var(--fl-faint); font-style: italic; margin: 0.75rem 0 0; }
    .fl .build-line { font-family: var(--fl-serif); font-size: 1.05rem; color: var(--fl-ink); margin: 0 0 0.75rem; }
    .fl .family-open { margin-top: 2.5rem; }
    .fl .family-open h3 { font-size: 1.2rem; margin: 0 0 1rem; }

    .fl .filters { display: flex; flex-wrap: wrap; gap: 1rem; margin: 0 0 1rem; }
    .fl .filters label {
      display: flex; flex-direction: column; gap: 0.3rem;
      font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fl-faint);
    }
    .fl .filters select {
      font-family: var(--fl-sans); font-size: 0.92rem; padding: 0.5rem 0.7rem;
      border: 1px solid var(--fl-border); border-radius: 8px; background: var(--fl-paper); color: var(--fl-ink);
    }
    .fl .filters select:focus-visible { outline: 2px solid var(--fl-accent); outline-offset: 2px; }
    .fl .count { font-size: 0.82rem; color: var(--fl-faint); margin: 0 0 1rem; }
    .fl .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
    .fl .empty { color: var(--fl-muted); }

    .fl .footer-disclaimer { background: var(--fl-surface); border-bottom: none; }
    .fl .footer-disclaimer p { font-size: 0.85rem; color: var(--fl-faint); margin: 0; }

    @media (max-width: 720px) {
      .fl .failure-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
      .fl .cards { grid-template-columns: 1fr; }
      .fl .filters label { flex: 1 1 45%; }
    }
  </style>
</BaseLayout>
