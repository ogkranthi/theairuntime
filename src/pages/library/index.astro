---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ReadingCard from '../../components/ReadingCard.astro';
import ToolCard from '../../components/ToolCard.astro';
import SubstackEmbed from '../../components/SubstackEmbed.astro';
import PillarFilter from '../../components/PillarFilter.astro';
import { fetchSubstackPosts } from '../../lib/substack';

const reading = await getCollection('reading');
const tools = await getCollection('tools');
tools.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return +b.data.addedAt - +a.data.addedAt;
});
const substackPosts = await fetchSubstackPosts(6);

const pillarOrder = ['evals', 'agents', 'inference', 'reliability', 'cost'] as const;
const pillarLabels: Record<string, string> = {
  evals: 'Evals & Observability',
  agents: 'Agents in Production',
  inference: 'Inference & Serving',
  reliability: 'Reliability & Incidents',
  cost: 'Cost & Performance',
};

const byPillar = pillarOrder.map((pillar) => ({
  pillar,
  label: pillarLabels[pillar],
  entries: reading
    .filter((r) => r.data.pillar === pillar)
    .sort((a, b) => {
      // highlight first, then newest first
      if (a.data.highlight !== b.data.highlight) return a.data.highlight ? -1 : 1;
      return +b.data.addedAt - +a.data.addedAt;
    }),
}));

const total = reading.length;
const highlights = reading.filter((r) => r.data.highlight).slice(0, 4);

// Pillar chips for the client-side topic filter (only non-empty pillars).
const pillarChips = byPillar
  .filter((p) => p.entries.length > 0)
  .map((p) => ({ key: p.pillar, label: p.label, count: p.entries.length }));
---
<BaseLayout
  title="The Production AI Reading List · The AI Runtime"
  description="Curated by The AI Runtime, the canonical reading list for AI practitioners. Evals, agents, inference, reliability, cost."
>
  <Section
    eyebrow="The library"
    title="The Production AI Reading List"
    lead="A living, curated reading list for AI practitioners. Organized by pillar. New entries added as we read them."
  >
    <PillarFilter mode="filter" pillars={pillarChips} />

    <p class="muted small toc-meta">{total} entries · curated by The AI Runtime · last updated {new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(new Date(Math.max(...reading.map((r) => +r.data.addedAt))))}</p>
  </Section>

  {substackPosts.length > 0 && (
    <Section eyebrow="From the publication" title="Latest from The AI Runtime">
      <p class="dim wide">
        Fresh issues from our own Substack, auto-pulled from the feed.
        <a href="https://theairuntime.com">See all issues →</a>
      </p>
      <div class="grid">
        {substackPosts.map((p) => (
          <article class="own">
            <header>
              <span class="tag">Issue</span>
              <span class="source muted">The AI Runtime · {new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(p.publishedAt)}</span>
            </header>
            <h3><a href={p.url} target="_blank" rel="noopener">{p.title}</a></h3>
            <p class="dim">{p.summary}</p>
          </article>
        ))}
      </div>
    </Section>
  )}

  {highlights.length > 0 && (
    <div data-pillar-section="all">
      <Section eyebrow="Start here" title="Highlights">
        <div class="grid">
          {highlights.map((r) => <ReadingCard entry={r} />)}
        </div>
      </Section>
    </div>
  )}

  {byPillar.filter((p) => p.entries.length > 0).map((p) => (
    <div data-pillar-section={p.pillar}>
      <Section id={p.pillar} eyebrow={p.label}>
        <div class="grid">
          {p.entries.map((r) => <ReadingCard entry={r} />)}
        </div>
      </Section>
    </div>
  ))}

  {tools.length > 0 && (
    <Section id="tools" eyebrow="Tools we use" title="Tools that earn their seat in the workflow">
      <p class="dim wide">
        Hand-picked tools we use day-to-day for shipping AI to production. Some links are referrals (clearly labeled);
        we only recommend what we'd recommend without one.
      </p>
      <div class="grid">
        {tools.map((t) => <ToolCard tool={t} />)}
      </div>
    </Section>
  )}

  <Section eyebrow="Subscribe" title="Get the Reading Roundup">
    <p class="dim wide">
      Every few weeks, we ship a Reading Roundup issue, the best new items added to the library, with editorial notes.
    </p>
    <SubstackEmbed
      source="library-roundup"
      headline="The AI Runtime newsletter"
      subhead="Production-grade reads, in your inbox."
    />
  </Section>

  <script>
    // Client-side topic filter. Toggles the `hidden` attribute on pillar
    // sections so the accessibility tree stays correct. No JS = all visible.
    const filter = document.querySelector('[data-pillar-filter]');
    const sections = document.querySelectorAll('[data-pillar-section]');
    filter?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button[data-pillar]') as HTMLElement | null;
      if (!btn) return;
      const want = btn.dataset.pillar;
      filter.querySelectorAll('button').forEach((b) =>
        b.setAttribute('aria-pressed', String(b === btn)),
      );
      filter.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === btn));
      sections.forEach((s) => {
        const sec = s as HTMLElement;
        sec.hidden = !(want === 'all' || sec.dataset.pillarSection === want);
      });
    });
  </script>
</BaseLayout>

<style>
  .toc {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .toc a {
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg-2);
    color: var(--text-2);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
  }
  .toc a:hover { border-color: var(--accent); color: var(--text); }
  .toc-meta { margin-top: 1rem; }
  .small { font-size: 0.85rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }
  .wide { max-width: 42rem; }
  .own {
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.06), var(--bg-2));
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .own header { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; font-size: 0.8rem; }
  .own .source { font-family: var(--font-mono); font-size: 0.78rem; }
  .own h3 { margin: 0; font-size: 1.1rem; }
  .own h3 a { color: var(--text); text-decoration: none; }
  .own h3 a:hover { color: var(--accent); }
</style>
