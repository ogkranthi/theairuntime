---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventHero from '../../components/EventHero.astro';
import AgendaList from '../../components/AgendaList.astro';
import SpeakerCard from '../../components/SpeakerCard.astro';
import PartnerStrip from '../../components/PartnerStrip.astro';
import Section from '../../components/Section.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import SubstackEmbed from '../../components/SubstackEmbed.astro';
import ReadingCard from '../../components/ReadingCard.astro';
import JsonLd from '../../components/JsonLd.astro';
import { breadcrumbList } from '../../lib/breadcrumbs';

export async function getStaticPaths() {
  const events = await getCollection('events', (e) => e.slug.startsWith('boston/'));
  return events.map((event) => ({
    params: { slug: event.slug.replace(/^boston\//, '') },
    props: { event },
  }));
}

const { event } = Astro.props;
const speakers = await Promise.all(
  event.data.speakers.map((ref) => getEntry('speakers', (ref as any).slug ?? (ref as any).id)),
);

const { Content: RecapBody } = await event.render();
const hasRecapBody = (event.body ?? '').trim().length > 0;
const hasRecap =
  hasRecapBody || event.data.recapTakeaways.length > 0 || event.data.recapPhotos.length > 0;

// Curated reading tied to this event via reading.relatedEvents (matches either
// the full slug or the date-only slug, the established pattern in /reading).
const eventDateSlug = event.slug.replace(/^boston\//, '');
const eventSlugRefs = [event.slug, eventDateSlug];
const allReading = await getCollection('reading');
const relatedReading = allReading
  .filter((r) => r.data.relatedEvents.some((e) => eventSlugRefs.includes(e)))
  .sort((a, b) => {
    if (a.data.highlight !== b.data.highlight) return a.data.highlight ? -1 : 1;
    return +b.data.addedAt - +a.data.addedAt;
  })
  .slice(0, 4);

// Schema.org Event, built from frontmatter so every event page is
// machine-readable for Google rich results and AI answer engines.
const d = event.data;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const toIso = (date: Date, time?: string) => {
  // Times in frontmatter are local (US/Eastern, -04:00 in summer).
  if (!time) return date.toISOString().slice(0, 10);
  const m = time.match(/(\d+):(\d+)\s*(AM|PM)?/i);
  if (!m) return date.toISOString().slice(0, 10);
  let h = parseInt(m[1], 10);
  const min = m[2];
  const mer = m[3]?.toUpperCase();
  if (mer === 'PM' && h !== 12) h += 12;
  if (mer === 'AM' && h === 12) h = 0;
  const y = date.getFullYear();
  const mo = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${y}-${mo}-${day}T${String(h).padStart(2, '0')}:${min}:00-04:00`;
};

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: d.title,
  description: d.description ?? `${d.title}, The AI Runtime Boston meetup.`,
  startDate: toIso(d.date, d.doorsAt ?? d.startsAt),
  ...(d.endsAt ? { endDate: toIso(d.date, d.endsAt) } : {}),
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  url: canonicalUrl,
  image: new URL('/og-default.png', Astro.site).toString(),
  ...(d.venue?.name
    ? {
        location: {
          '@type': 'Place',
          name: d.venue.name,
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Cambridge',
            addressRegion: 'MA',
            addressCountry: 'US',
          },
        },
      }
    : {}),
  organizer: {
    '@type': 'Organization',
    name: 'The AI Runtime',
    url: 'https://theairuntime.com',
  },
  performer: speakers
    .filter((s): s is NonNullable<typeof s> => !!s)
    .map((s) => ({
      '@type': 'Person',
      name: s.data.name,
      jobTitle: s.data.title,
      worksFor: { '@type': 'Organization', name: s.data.company },
    })),
  ...(d.lumaUrl
    ? {
        offers: {
          '@type': 'Offer',
          name: 'RSVP',
          price: '0',
          priceCurrency: 'USD',
          availability: 'https://schema.org/InStock',
          url: d.lumaUrl,
        },
      }
    : {}),
  isAccessibleForFree: true,
};

const breadcrumbSchema = breadcrumbList(
  [
    { name: 'Boston', path: '/boston' },
    { name: d.title, path: `/boston/${event.slug.replace(/^boston\//, '')}` },
  ],
  Astro.site,
);
---
<BaseLayout
  title={`${event.data.title} · Boston · The AI Runtime`}
  description={event.data.description ?? `${event.data.title}, The AI Runtime Boston meetup.`}
>
  <JsonLd slot="jsonld" schema={[eventSchema, breadcrumbSchema]} />
  <EventHero event={event} />

  <Section id="speakers" eyebrow="Speakers" title="Who shared what">
    <div class="grid">
      {speakers.map((s) => s && <SpeakerCard speaker={s} eventSlug={event.slug} />)}
    </div>
  </Section>

  <Section id="agenda" eyebrow="Agenda">
    <AgendaList agenda={event.data.agenda} />
    {event.data.status === 'upcoming' && (
      <p class="cal-cta">
        {event.data.lumaUrl && (
          <a class="btn" href={event.data.lumaUrl} target="_blank" rel="noopener">RSVP on Luma</a>
        )}
        <a class="btn btn-ghost" href={`/boston/${eventDateSlug}.ics`} download>Add to calendar</a>
      </p>
    )}
    <div class="partners"><PartnerStrip partners={event.data.partners} /></div>
  </Section>

  {(event.data.recordingUrl || event.data.slidesUrl) && (
    <Section eyebrow="Materials" title="Slides and recordings">
      <ul class="materials">
        {event.data.slidesUrl && <li><a href={event.data.slidesUrl}>Slides →</a></li>}
        {event.data.recordingUrl && <li><a href={event.data.recordingUrl}>Recording →</a></li>}
      </ul>
    </Section>
  )}

  {event.data.status === 'past' && hasRecap && (
    <Section id="recap" eyebrow="Recap" title="What happened">
      {hasRecapBody && (
        <div class="recap-body dim"><RecapBody /></div>
      )}
      {event.data.recapTakeaways.length > 0 && (
        <ul class="takeaways">
          {event.data.recapTakeaways.map((t) => (
            <li>
              {t.speaker && <span class="who">{t.speaker}</span>}
              <span class="point">{t.point}</span>
            </li>
          ))}
        </ul>
      )}
      {event.data.recapPhotos.length > 0 && (
        <ul class="photos">
          {event.data.recapPhotos.map((p) => (
            <li><img src={p.src} alt={p.alt} loading="lazy" /></li>
          ))}
        </ul>
      )}
    </Section>
  )}

  <Section eyebrow="Background reading" title="Curated for this event">
    {relatedReading.length > 0 && (
      <div class="reading-grid">
        {relatedReading.map((r) => <ReadingCard entry={r} />)}
      </div>
    )}
    <p class="reading-cta">
      <a class="btn" href={`/boston/${eventDateSlug}/reading`}>See the full reading list →</a>
    </p>
  </Section>

  <Section eyebrow="Subscribe" title={event.data.status === 'past' ? 'Missed it? Get the next one.' : 'Get the recap'}>
    <p class="dim wide">
      {event.data.status === 'past'
        ? 'Subscribers get the recap, slides, and the next Boston event before the public Luma drop.'
        : 'Slides, recording, and the recap will land here within a week, and in subscribers\' inboxes first.'}
    </p>
    <SubstackEmbed
      source={event.data.status === 'past' ? 'past-event' : 'upcoming-event'}
      headline="The AI Runtime newsletter"
      subhead="Production lessons from AI practitioners. New issues every week."
    />
  </Section>

  <Section><ContactCTA /></Section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 720px) { .grid { grid-template-columns: 1fr; } }
  .partners { margin-top: 1.5rem; }
  .cal-cta { display: flex; gap: 0.75rem; flex-wrap: wrap; margin: 1.5rem 0 0; }
  .materials { list-style: none; padding: 0; margin: 0; display: flex; gap: 1rem; }
  .reading-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .reading-cta { margin: 0; }
  .wide { max-width: 42rem; }
  .recap-body { max-width: 42rem; }
  .recap-body :global(p) { margin-bottom: 0.85rem; }
  .takeaways {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 42rem;
  }
  .takeaways li {
    padding: 0.85rem 1rem;
    border-left: 2px solid var(--accent);
  }
  .takeaways .who {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }
  .takeaways .point { color: var(--text-2); }
  .photos {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.5rem;
  }
  .photos img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }
</style>
