---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventHero from '../../components/EventHero.astro';
import AgendaList from '../../components/AgendaList.astro';
import SpeakerCard from '../../components/SpeakerCard.astro';
import PartnerStrip from '../../components/PartnerStrip.astro';
import SubstackEmbed from '../../components/SubstackEmbed.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Section from '../../components/Section.astro';
import JsonLd from '../../components/JsonLd.astro';

const allEvents = await getCollection('events', (e) => e.slug.startsWith('boston/'));
allEvents.sort((a, b) => +b.data.date - +a.data.date);

const upcoming = allEvents.find((e) => e.data.status === 'upcoming') ?? allEvents[0];
if (!upcoming) {
  throw new Error('No Boston events found in src/content/events/boston/');
}
const past = allEvents.filter((e) => e.id !== upcoming.id);

const speakers = await Promise.all(
  upcoming.data.speakers.map((ref) => getEntry('speakers', (ref as any).slug ?? (ref as any).id)),
);

const city = await getEntry('cities', 'boston');

// Event schema for the canonical /boston/ hub (the active upcoming event).
const d = upcoming.data;
const toIso = (date: Date, time?: string) => {
  if (!time) return date.toISOString().slice(0, 10);
  const m = time.match(/(\d+):(\d+)\s*(AM|PM)?/i);
  if (!m) return date.toISOString().slice(0, 10);
  let h = parseInt(m[1], 10);
  const mer = m[3]?.toUpperCase();
  if (mer === 'PM' && h !== 12) h += 12;
  if (mer === 'AM' && h === 12) h = 0;
  const y = date.getFullYear();
  const mo = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${y}-${mo}-${day}T${String(h).padStart(2, '0')}:${m[2]}:00-04:00`;
};
const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: d.title,
  description: d.description ?? `${d.title}, The AI Runtime Boston meetup.`,
  startDate: toIso(d.date, d.doorsAt ?? d.startsAt),
  ...(d.endsAt ? { endDate: toIso(d.date, d.endsAt) } : {}),
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  url: new URL('/boston/', Astro.site).toString(),
  image: new URL('/og-default.png', Astro.site).toString(),
  ...(d.venue?.name
    ? {
        location: {
          '@type': 'Place',
          name: d.venue.name,
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Cambridge',
            addressRegion: 'MA',
            addressCountry: 'US',
          },
        },
      }
    : {}),
  organizer: { '@type': 'Organization', name: 'The AI Runtime', url: 'https://theairuntime.com' },
  performer: speakers
    .filter((s): s is NonNullable<typeof s> => !!s)
    .map((s) => ({
      '@type': 'Person',
      name: s.data.name,
      jobTitle: s.data.title,
      worksFor: { '@type': 'Organization', name: s.data.company },
    })),
  ...(d.lumaUrl
    ? {
        offers: {
          '@type': 'Offer',
          name: 'RSVP',
          price: '0',
          priceCurrency: 'USD',
          availability: 'https://schema.org/InStock',
          url: d.lumaUrl,
        },
      }
    : {}),
  isAccessibleForFree: true,
};
---
<BaseLayout
  title="Boston · The AI Runtime"
  description={`${upcoming.data.title}, ${upcoming.data.speakers.length} talks on the production engineering of AI agents. ${city?.data.venueName ?? ''}`}
>
  <JsonLd slot="jsonld" schema={eventSchema} />
  <EventHero event={upcoming} />

  <Section id="speakers" eyebrow="Tonight's lineup" title="Two practitioners. Two production stories.">
    <div class="speakers-grid">
      {speakers.map((s) => s && <SpeakerCard speaker={s} eventSlug={upcoming.slug} />)}
    </div>
  </Section>

  <Section id="agenda" eyebrow="Agenda" title="How the night runs">
    <AgendaList agenda={upcoming.data.agenda} />
    <div class="partner-wrap">
      <PartnerStrip partners={upcoming.data.partners} />
    </div>
  </Section>

  <Section eyebrow="Subscribe" title="Get the recap, and the next event before it sells out">
    <p class="dim wide">
      Slides and links from tonight's talks land here Thursday. Subscribers get the recap first, and an
      invite to next month's Boston meetup before the public Luma drop.
    </p>
    <SubstackEmbed
      headline="The AI Runtime newsletter"
      subhead="Production lessons from AI practitioners. New issues every week."
    />
    <p class="muted small luma">
      Prefer just the calendar? <a href="https://luma.com/tair">Subscribe to the Boston meetup on Luma →</a>
    </p>
  </Section>

  <Section eyebrow="Background reading" title="Read before the talks">
    <p class="dim wide">
      A curated reading list for tonight's topics, agent architectures, identity for agents, and the gap
      between AI demos and production. Free, all from primary sources.
    </p>
    <p>
      <a class="btn" href={`/boston/${upcoming.slug.replace(/^boston\//, '')}/reading`}>See the reading list →</a>
      <a class="btn btn-ghost" href="/library">Full library</a>
    </p>
  </Section>

  <Section eyebrow="Free resource" title="The AI Runtime Field Guide">
    <p class="dim wide">
      A guided reading path through The AI Runtime for AI practitioners. AI engineering, Model Reliability
      Engineering, and vertical agents, in the order that builds real production intuition. Free, no email required.
    </p>
    <p>
      <a class="btn" href="/resources/the-ai-runtime-field-guide.pdf" download>Download the PDF →</a>
      <a class="btn btn-ghost" href="/resources">All resources</a>
    </p>
  </Section>

  {past.length > 0 && (
    <Section eyebrow="Archive" title="Past Boston events">
      <ul class="past">
        {past.map((e) => (
          <li>
            <a href={`/boston/${e.slug.replace(/^boston\//, '')}`}>
              <span class="date">{new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(e.data.date)}</span>
              <span class="title">{e.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </Section>
  )}

  <Section>
    <ContactCTA />
  </Section>
</BaseLayout>

<style>
  .speakers-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 720px) {
    .speakers-grid { grid-template-columns: 1fr; }
  }
  .partner-wrap { margin-top: 1.5rem; }
  .wide { max-width: 42rem; }
  .luma { margin-top: 1rem; }
  .small { font-size: 0.9rem; }
  .past {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .past a {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    text-decoration: none;
  }
  .past a:hover { border-color: var(--accent); }
  .past .date { font-family: var(--font-mono); color: var(--text-3); font-size: 0.85rem; }
</style>
