---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ReadingCard from '../../components/ReadingCard.astro';
import SubstackEmbed from '../../components/SubstackEmbed.astro';
import JsonLd from '../../components/JsonLd.astro';
import { breadcrumbList } from '../../lib/breadcrumbs';

export async function getStaticPaths() {
  const speakers = await getCollection('speakers');
  return speakers.map((speaker) => ({
    params: { slug: speaker.slug },
    props: { speaker },
  }));
}

const { speaker } = Astro.props;
const { Content } = await speaker.render();
const data = speaker.data;
const initials = data.name.split(' ').map((p) => p[0]).slice(0, 2).join('');

const allReading = await getCollection('reading');
const recommendedReading = allReading
  .filter((r) => r.data.relatedSpeakers.some((s: any) => (s.slug ?? s.id) === speaker.slug))
  .sort((a, b) => +b.data.addedAt - +a.data.addedAt);

// Person schema, makes each speaker an entity AI engines can recognize
// and attribute talks to.
const sameAs = [
  data.social.linkedin,
  data.social.twitter,
  data.social.github,
  data.social.website,
].filter((u): u is string => !!u);
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.name,
  jobTitle: data.title,
  worksFor: { '@type': 'Organization', name: data.company },
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  ...(data.photo ? { image: new URL(data.photo, Astro.site).toString() } : {}),
  ...(sameAs.length ? { sameAs } : {}),
  ...(data.talks.length
    ? {
        performerIn: data.talks.map((t) => ({
          '@type': 'Event',
          name: t.title,
          organizer: { '@type': 'Organization', name: 'The AI Runtime' },
        })),
      }
    : {}),
};

const breadcrumbSchema = breadcrumbList(
  [
    { name: 'Speakers', path: '/speakers' },
    { name: data.name, path: `/speakers/${speaker.slug}` },
  ],
  Astro.site,
);
---
<BaseLayout
  title={`${data.name} · The AI Runtime`}
  description={`${data.name}, ${data.title} at ${data.company}. ${data.talks[0]?.title ?? ''}`}
  ogType="profile"
>
  <JsonLd slot="jsonld" schema={[personSchema, breadcrumbSchema]} />
  <Section eyebrow="Speaker">
    <div class="head">
      <div class="avatar">
        {data.photo ? <img src={data.photo} alt={data.name} /> : <span>{initials}</span>}
      </div>
      <div>
        <h1>{data.name}</h1>
        <p class="role">{data.title} · {data.company}</p>
        <div class="links">
          {data.social.linkedin && <a href={data.social.linkedin}>LinkedIn</a>}
          {data.social.twitter && <a href={data.social.twitter}>Twitter</a>}
          {data.social.github && <a href={data.social.github}>GitHub</a>}
          {data.social.website && <a href={data.social.website}>Website</a>}
        </div>
      </div>
    </div>

    <div class="bio dim"><Content /></div>

    {data.talks.length > 0 && (
      <div class="talks">
        <h2>Talks</h2>
        <ul>
          {data.talks.map((t) => (
            <li>
              <h3>{t.title}</h3>
              <p class="dim">{t.abstract}</p>
              <div class="talk-links">
                {t.slidesUrl && <a href={t.slidesUrl}>Slides →</a>}
                {t.recordingUrl && <a href={t.recordingUrl}>Recording →</a>}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}
  </Section>

  {recommendedReading.length > 0 && (
    <Section eyebrow="Recommended reading" title="Background from our library">
      <p class="dim wide">Curated picks from <a href="/library">The AI Runtime library</a> that align with {data.name}'s work.</p>
      <div class="reading-grid">
        {recommendedReading.map((r) => <ReadingCard entry={r} />)}
      </div>
    </Section>
  )}

  <Section eyebrow="Subscribe" title="Get more talks like this one">
    <p class="dim wide">
      The AI Runtime publishes weekly issues from practitioners shipping AI to production,
      and announces every new meetup talk first.
    </p>
    <SubstackEmbed
      source="speaker-page"
      headline="Practitioner stories, in your inbox"
      subhead="One issue a week. Future meetup talks announced here first."
    />
  </Section>
</BaseLayout>

<style>
  .head {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 2rem;
  }
  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 2rem;
    display: grid;
    place-items: center;
    overflow: hidden;
    flex-shrink: 0;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }
  .role { color: var(--text-2); font-size: 1rem; margin-bottom: 0.5rem; }
  .links { display: flex; gap: 1rem; font-family: var(--font-mono); font-size: 0.9rem; }
  .bio { max-width: 38rem; margin-bottom: 2.5rem; }
  .talks ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1.5rem; }
  .talks li {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .talks h2 { margin-bottom: 1rem; }
  .talks h3 { margin-bottom: 0.5rem; }
  .talk-links { display: flex; gap: 1rem; margin-top: 0.5rem; }
  .reading-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .wide { max-width: 42rem; }
</style>
