---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import QRCode from '../components/QRCode.astro';
import SubstackEmbed from '../components/SubstackEmbed.astro';
import SubscribePopup from '../components/SubscribePopup.tsx';

// ─────────────────────────────────────────────────────────────────────
// Talk metadata. Pulled from the live deck:
// "From Chaos to Control: Managing Agents at Scale" / "The Agent 365 Control Plane".
// ─────────────────────────────────────────────────────────────────────

const TALK = {
  title: 'From Chaos to Control: Managing AI Agents at Scale with Agent 365',
  conference: 'DeveloperWeek New York · AI DevSummit',
  date: 'June 9, 2026',
  thesis: 'Identity, security, and observability for AI agents, at enterprise scale.',
  slidesUrl: '/slides/agent-365.pdf',
  slidesLabel: 'Download the deck (PDF)',
};

// ── Slide 2 ─ The Shift ─
const SHIFT_BULLETS = [
  {
    title: 'They span everything',
    body: 'Copilot, Teams, and M365, plus local assistants and SaaS agents on emerging platforms.',
  },
  {
    title: 'They act, not just chat',
    body: 'Invoke tools, access data, and talk to other agents. Decisions happen in seconds.',
  },
  {
    title: 'They multiply fast',
    body: 'Easier to build and deploy means your attack surface grows with every new agent.',
  },
];

// ── Slide 3 ─ The Problem ─
const PROBLEMS = [
  {
    title: 'Invisible',
    body: 'No inventory, no owner. Shadow and ownerless agents run outside the view of the teams accountable for risk.',
  },
  {
    title: 'Insecure',
    body: 'Over-privileged access, tool misuse, and prompt injection turn a "helpful" workflow into data oversharing in seconds.',
  },
  {
    title: 'Unmanaged',
    body: 'Built across many tools and frameworks with no consistent policy, lifecycle, or audit trail.',
  },
];

// ── Slide 4 ─ The Answer (Observe / Govern / Secure) ─
const PILLARS = [
  {
    n: '01',
    title: 'Observe',
    body: 'One inventory of every agent: telemetry, dashboards, and an agent map across the whole fleet.',
  },
  {
    n: '02',
    title: 'Govern',
    body: 'Identity, least-privilege access, policy templates, and full lifecycle. Manage agents like your workforce.',
  },
  {
    n: '03',
    title: 'Secure',
    body: 'Runtime threat detection, prompt-injection defense, DLP, and compliance built in.',
  },
];

// ── Slide 5 ─ Architecture ─
const STACK = [
  { name: 'Microsoft Entra', body: 'Agent ID, the identity and access-control foundation.' },
  { name: 'Microsoft Defender', body: 'Threat detection, runtime protection, shadow-AI discovery.' },
  { name: 'Microsoft Purview', body: 'Data security and compliance: DLP, sensitivity labels, eDiscovery.' },
  { name: 'Intune + Windows 365', body: 'Device discovery and a secured, managed runtime.' },
];

// ── Slides 6-11 ─ Five Capabilities ─
const CAPABILITIES = [
  {
    n: '01',
    title: 'Registry',
    sub: 'Stop sprawl at the source: one inventory of every agent.',
    does: 'Single source of truth across Entra Agent ID, Teams Store, and discovered shadow agents. Defender + Intune find local and cloud agents on the Shadow AI page. Unsanctioned agents are quarantined on day one. Registry sync extends to AWS Bedrock and Google Cloud (preview).',
    learned: 'Make discovery continuous, not a one-time audit. Require an owner at registration; a registry without owners is just a list. Quarantine the unsanctioned first, then onboard the rest under policy.',
  },
  {
    n: '02',
    title: 'Access Control',
    sub: 'Every agent gets a unique identity, and only the access it needs.',
    does: 'Unique Agent ID per agent (no shared service accounts). Least privilege by default: scope access to the task, shrink the blast radius. Policy templates enforce a baseline at onboarding. Adaptive Conditional Access via Entra applies risk-based policy in real time and blocks compromised agents.',
    learned: 'One Agent ID per agent, scoped tightly to its task. Enforce the baseline with policy templates at onboarding, not later. Let Conditional Access revoke access automatically on risk signals.',
  },
  {
    n: '03',
    title: 'Visualization',
    sub: 'Move from monitoring to actionable insight across the fleet.',
    does: 'An Agent Map of every connection among agents, users, and resources. Telemetry and alerts with anomaly detection so blind spots do not become incidents. Role-based reporting: IT, security, and business leaders each see the metrics that matter. Per-agent performance plus logging and eDiscovery to stay audit-ready.',
    learned: 'Define alerts and ROI metrics before go-live, not after. Use the Agent Map to trace every agent-to-data path. Give IT, security, and business their own role-based views.',
  },
  {
    n: '04',
    title: 'Interoperability',
    sub: 'Agents get the same context as the people they work alongside.',
    does: 'Native M365 access (Word, Excel, SharePoint, Dynamics 365), the same data your users touch. Framework-agnostic: Microsoft, open-source, and third-party agents are first-class. Secure agent-to-agent interop without bespoke plumbing. Three operating modes: delegated and behind-the-scenes are GA; team workflows in preview.',
    learned: 'Grant task-scoped access through the Agent ID, never standing broad rights. Treat interop as a privilege to scope, not a door to leave open. Make OSS and third-party agents first-class, but governed.',
  },
  {
    n: '05',
    title: 'Security',
    sub: 'Defense in depth, from runtime behavior to the data agents touch.',
    does: 'Defender XDR detects threats and protects agents as they execute. Network-level protection stops prompt injection before it reaches the agent. Purview DSPM for AI, DLP, and sensitivity labels guard against oversharing. Insider risk and audit: detect, retain, and investigate risky agent interactions.',
    learned: 'Layer runtime + network + data controls. One guardrail is not enough. Assume the agent is a target and plan blast-radius containment. Use Purview DSPM/DLP to catch oversharing before it ships.',
  },
];

// ── Slide 12 ─ Six Best Practices ─
const BEST_PRACTICES = [
  { n: '01', title: 'Manage agents like a workforce', body: 'Onboard, assign an owner, and offboard. No ownerless agents.' },
  { n: '02', title: 'Identity-first, least privilege', body: 'A unique Agent ID per agent, scoped to its task. Templates enforce the baseline.' },
  { n: '03', title: 'Discover before you govern', body: 'Switch on shadow-AI discovery early. Quarantine, then bring the rest under policy.' },
  { n: '04', title: 'Instrument for observability', body: 'Define alerts and ROI metrics at launch. Watch agent-to-resource paths.' },
  { n: '05', title: 'Layer your defenses', body: 'Runtime + network + data controls together. Assume compromise.' },
  { n: '06', title: 'Reuse the trust fabric', body: 'Extend Entra, Defender, and Purview. Do not rebuild governance.' },
];

// ── Slide 13 ─ Crawl / Walk / Run ─
const ROADMAP = [
  {
    n: '01',
    phase: 'Crawl',
    sub: 'Discover & inventory',
    bullets: ['Enable registry + shadow-AI discovery', 'Baseline every agent and its owner', 'Quarantine the unsanctioned'],
  },
  {
    n: '02',
    phase: 'Walk',
    sub: 'Govern',
    bullets: ['Apply policy templates and least privilege', 'Adaptive Conditional Access via Entra', 'Stand up dashboards and alerts'],
  },
  {
    n: '03',
    phase: 'Run',
    sub: 'Secure & scale',
    bullets: ['Runtime + prompt-injection defense', 'Purview DLP, labels, and eDiscovery', 'Measure ROI; sync multi-cloud agents'],
  },
];

// ── Slides 14, 15 ─ Customer case studies ─
// Content lifted from the live deck and the Microsoft customer stories cited on
// those slides (Microsoft Ignite 2025).
const CASE_STUDIES = [
  {
    org: 'Amgen',
    industry: 'Biotechnology & R&D',
    title: 'From concept to a governed R&D agent in just six weeks.',
    challenge: 'Speed up drug research without adding new governance or security risk.',
    agent: 'An R&D agent that mines research data and drafts scientific insights.',
    governance: 'A unique Entra Agent ID, least-privilege access, and full auditability.',
    outcomeLabel: '6 weeks',
    outcomeBody: 'From idea to a production-ready, governed agent.',
    outcomeBullets: ['Built with Microsoft Copilot Studio', 'Observed and secured end-to-end in Agent 365'],
    source: 'Microsoft customer stories · Microsoft Ignite 2025',
  },
  {
    org: 'Dow',
    industry: 'Materials Science',
    title: 'Reimagining productivity and supply chain with a fleet of agents.',
    challenge: 'Scale agents across global operations without losing oversight.',
    agent: 'Productivity and supply-chain agents working alongside employees.',
    governance: 'One control plane to observe, secure, and measure the whole fleet.',
    outcomeLabel: 'Millions',
    outcomeBody: 'In targeted cost savings across global productivity and supply chain.',
    outcomeBullets: ['Powered by Microsoft 365 Copilot and agents', 'Every agent carries a governed identity'],
    source: 'Microsoft customer stories · Microsoft Ignite 2025',
  },
];

// ── Slide 16 ─ Three takeaways ─
const TAKEAWAYS = [
  {
    n: '01',
    title: 'Visibility is the prerequisite',
    body: 'You cannot govern or secure what you cannot see. Start with discovery and a single registry.',
  },
  {
    n: '02',
    title: 'Identity is the control point',
    body: 'A unique Agent ID with least-privilege access turns ungoverned agents into managed ones.',
  },
  {
    n: '03',
    title: "Extend, don't rebuild",
    body: 'Agent 365 brings agents into Entra, Defender, and Purview, the trust fabric you already run.',
  },
];

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
---
<BaseLayout
  title={`${TALK.title} · The AI Runtime`}
  description={TALK.thesis}
  ogType="article"
  noSubBar
>
  <Section eyebrow={`Best Practices Session · ${TALK.conference} · ${TALK.date}`}>
    <div class="hero">
      <div>
        <h1>{TALK.title}</h1>
        <p class="subtitle">The Agent 365 Control Plane</p>
        <p class="thesis">{TALK.thesis}</p>
        <div class="speaker">
          <strong>Kranthi Kumar Manchikanti</strong>
          <span class="muted">AI Architect · Microsoft · Editor, The AI Runtime</span>
        </div>
        <div class="cta">
          <a class="btn" href={TALK.slidesUrl} target="_blank" rel="noopener">{TALK.slidesLabel} →</a>
          <a class="btn btn-ghost" href="#takeaways">Three takeaways ↓</a>
        </div>
        <p class="ga muted small">Agent 365 · Generally available May 2026</p>
      </div>
      <aside class="qr-block">
        <QRCode value={pageUrl} size={260} />
        <p class="qr-cap muted small">Scan to revisit on your phone.</p>
        <p class="qr-url muted small"><code>events.theairuntime.com/agent-365</code></p>
      </aside>
    </div>
  </Section>

  <Section eyebrow="The shift" title="Agents are no longer coming. They're already here.">
    <div class="shift">
      <div class="stat">
        <div class="num">1.3B</div>
        <div class="label muted">agents in enterprises by 2028</div>
        <div class="src muted small">Directional. IDC projection.</div>
      </div>
      <ul class="bullets">
        {SHIFT_BULLETS.map((b) => (
          <li>
            <h3>{b.title}</h3>
            <p class="dim">{b.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </Section>

  <Section eyebrow="The problem" title="Without a control plane, agents become...">
    <ul class="problems">
      {PROBLEMS.map((p) => (
        <li>
          <h3>{p.title}</h3>
          <p class="dim">{p.body}</p>
        </li>
      ))}
    </ul>
    <p class="quote">You can't govern what you can't see, and you can't secure what you don't understand.</p>
  </Section>

  <Section eyebrow="The answer" title="Agent 365: the control plane for AI agents">
    <p class="dim wide">
      Observe, govern, and secure every agent (Microsoft-built, open-source, or third-party) using
      the admin and security workflows your teams already run.
    </p>
    <ul class="pillars">
      {PILLARS.map((p) => (
        <li>
          <span class="num">{p.n}</span>
          <h3>{p.title}</h3>
          <p class="dim">{p.body}</p>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Architecture" title="Built on the systems that already run your enterprise">
    <p class="dim wide">
      Your agents (Copilot, Teams, open-source, SaaS, custom) sit on top. The control plane handles
      Registry · Access Control · Visualization · Interoperability · Security. The four Microsoft
      services below are the trust fabric.
    </p>
    <ul class="stack">
      {STACK.map((s) => (
        <li>
          <h3>{s.name}</h3>
          <p class="dim">{s.body}</p>
        </li>
      ))}
    </ul>
    <p class="quote">No new trust fabric to rebuild. The same identity, security, and compliance stack, now covering agents.</p>
  </Section>

  <Section eyebrow="The control plane" title="Five capabilities that make enterprise-scale agents possible">
    <ul class="capabilities">
      {CAPABILITIES.map((c) => (
        <li>
          <header>
            <span class="num">{c.n}</span>
            <div>
              <h3>{c.title}</h3>
              <p class="sub dim">{c.sub}</p>
            </div>
          </header>
          <div class="block">
            <span class="label">What it does</span>
            <p class="dim">{c.does}</p>
          </div>
          <div class="block">
            <span class="label">What we learned</span>
            <p class="dim">{c.learned}</p>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Best practices" title="Patterns for safely scaling agent-based solutions">
    <ul class="practices">
      {BEST_PRACTICES.map((p) => (
        <li>
          <span class="num">{p.n}</span>
          <div>
            <h3>{p.title}</h3>
            <p class="dim">{p.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Adoption roadmap" title="From where you are to enterprise AI at scale">
    <ul class="roadmap">
      {ROADMAP.map((r) => (
        <li>
          <header>
            <span class="num">{r.n}</span>
            <h3>{r.phase}</h3>
          </header>
          <p class="sub dim">{r.sub}</p>
          <ul class="rb">
            {r.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="In production" title="Customer stories">
    <p class="dim wide">
      Two enterprise rollouts of Agent 365 from the live deck. Both sourced from Microsoft
      customer stories published at Microsoft Ignite 2025.
    </p>
    <ul class="cases">
      {CASE_STUDIES.map((c) => (
        <li>
          <header>
            <span class="industry">{c.industry}</span>
            <span class="wordmark">{c.org}</span>
          </header>
          <h3>{c.title}</h3>
          <dl class="meta">
            <dt>The challenge</dt>
            <dd>{c.challenge}</dd>
            <dt>The agent</dt>
            <dd>{c.agent}</dd>
            <dt>Governed by Agent 365</dt>
            <dd>{c.governance}</dd>
          </dl>
          <div class="outcome">
            <div class="ol">{c.outcomeLabel}</div>
            <div class="ob dim">{c.outcomeBody}</div>
            <ul class="ou">
              {c.outcomeBullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
          <p class="src muted small">Source: {c.source}</p>
        </li>
      ))}
    </ul>
  </Section>

  <Section id="takeaways" eyebrow="Takeaways" title="If you remember three things">
    <ul class="takeaways">
      {TAKEAWAYS.map((t) => (
        <li>
          <span class="num">{t.n}</span>
          <div>
            <h3>{t.title}</h3>
            <p class="dim">{t.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Go deeper" title="Where to read more">
    <ul class="deeper">
      <li>
        <h3><a href="https://aka.ms/Agent365" target="_blank" rel="noopener">aka.ms/Agent365</a></h3>
        <p class="dim">The official Agent 365 home: product, docs, and roadmap.</p>
      </li>
      <li>
        <h3>Agent Governance Whitepaper</h3>
        <p class="dim">Microsoft's published guidance on operating agents at enterprise scale. Linked from aka.ms/Agent365.</p>
      </li>
      <li>
        <h3><a href="/slides/agent-365.pdf" target="_blank" rel="noopener">This deck (PDF)</a></h3>
        <p class="dim">The 17-slide deck from the session, with capability breakdowns and the customer stories.</p>
      </li>
    </ul>
  </Section>

  <Section id="subscribe" eyebrow="Subscribe" title="Get production lessons in your inbox">
    <SubstackEmbed
      source="agent-365"
      headline="The AI Runtime newsletter"
      subhead="Weekly issues on Vertical AI Agents, Model Reliability Engineering, and lessons from the trenches. For practitioners shipping AI to production."
    />
  </Section>

  <SubscribePopup
    client:idle
    source="agent-365-popup"
    delayMs={18000}
    scrollPercent={45}
    headline="Liked the field guide? Get the next one."
    subhead="The AI Runtime publishes weekly issues on Vertical AI Agents, Model Reliability Engineering, and lessons from the trenches, for practitioners shipping AI to production."
  />
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.6fr auto;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 720px) { .hero { grid-template-columns: 1fr; } }
  .subtitle {
    font-family: var(--font-mono);
    color: var(--accent);
    margin: 0 0 0.6rem;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
  }
  .thesis {
    font-size: 1.15rem;
    max-width: 36rem;
    margin: 0.4rem 0 0;
    color: var(--text);
    font-style: italic;
  }
  .speaker {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .speaker strong { color: var(--text); font-size: 1rem; }
  .speaker .muted { font-size: 0.85rem; }
  .cta {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }
  .ga { margin: 1rem 0 0; font-family: var(--font-mono); }
  .qr-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    max-width: 320px;
  }
  .qr-cap { margin: 0.5rem 0 0; text-align: center; }
  .qr-url { margin: 0; text-align: center; }
  .qr-url code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-3);
  }

  /* The Shift */
  .shift {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) 2fr;
    gap: 2rem;
    align-items: start;
    margin-top: 1.5rem;
  }
  @media (max-width: 720px) { .shift { grid-template-columns: 1fr; } }
  .stat {
    padding: 2rem 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-align: center;
  }
  .stat .num {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat .label { margin-top: 0.5rem; font-family: var(--font-mono); }
  .stat .src { margin-top: 1rem; font-style: italic; }
  .bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .bullets li {
    padding: 1rem 1.25rem;
    border-left: 3px solid var(--accent);
  }
  .bullets h3 { margin: 0 0 0.3rem; font-size: 1rem; }
  .bullets p { margin: 0; }

  /* The Problem */
  .problems {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .problems li {
    padding: 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .problems h3 { color: var(--accent); margin: 0 0 0.5rem; }
  .problems p { margin: 0; }
  .quote {
    margin: 1.5rem 0 0;
    padding: 1rem 1.25rem;
    font-style: italic;
    color: var(--text);
    max-width: 42rem;
    border-left: 3px solid var(--accent);
  }

  /* Pillars (Observe / Govern / Secure) */
  .pillars {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .pillars li {
    padding: 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .pillars .num {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
  }
  .pillars h3 { margin: 0; }
  .pillars p { margin: 0; }

  /* Stack */
  .stack {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .stack li {
    padding: 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .stack h3 { font-size: 1rem; margin: 0 0 0.4rem; }
  .stack p { margin: 0; }

  /* Capabilities */
  .capabilities {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }
  .capabilities > li {
    padding: 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .capabilities > li > header {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
  }
  .capabilities .num {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 700;
    font-size: 1.6rem;
    line-height: 1;
  }
  .capabilities h3 { margin: 0; font-size: 1.1rem; }
  .capabilities .sub { margin: 0.2rem 0 0; font-style: italic; font-size: 0.92rem; }
  .capabilities .block {
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }
  .capabilities .label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: 0.3rem;
  }
  .capabilities .block p { margin: 0; font-size: 0.92rem; }

  /* Best practices */
  .practices {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .practices li {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .practices .num {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    font-size: 1.05rem;
    flex-shrink: 0;
  }
  .practices h3 { margin: 0 0 0.3rem; font-size: 1rem; }
  .practices p { margin: 0; }

  /* Roadmap (Crawl / Walk / Run) */
  .roadmap {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
