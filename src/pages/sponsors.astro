---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

// Partner cards lead with a styled wordmark of the name. If you later have
// permission-cleared logo SVGs, drop them at /public/logos/<slug>.svg and
// flip on the optional `logo` field per entry; the rendering already
// supports it.
const platformPartners = [
  {
    name: 'Microsoft',
    role: 'Space Partner',
    url: 'https://www.microsoft.com',
    blurb: 'Microsoft hosts our Boston meetups, the room in Kendall Square where practitioners gather, and brings the platform many of them ship on: Azure AI Foundry, Entra ID, and Agent 365.',
  },
  {
    name: 'NVIDIA',
    role: 'Food & Drinks Partner',
    url: 'https://www.nvidia.com',
    blurb: 'NVIDIA covers the food and drinks at our Boston meetups, keeping practitioners fed while they talk shop. Also the compute stack many reach for when training, evaluating, and serving models at production scale.',
  },
  {
    name: 'HackerSquad',
    role: 'Technology Partner',
    url: 'https://hackersquad.com',
    blurb: 'Technology partner for The AI Runtime, supporting the platform behind the events and the community.',
  },
];

const tiers = [
  {
    name: 'Space host',
    body: 'Host an upcoming meetup. Capacity for ~40 practitioners, A/V for two talks, space to mingle. We bring the audience and the program; you bring the room. Microsoft currently hosts the Boston space.',
  },
  {
    name: 'Refreshments',
    body: 'Cover food and drinks for one or more events. Logo on the event page, mention from the stage, name in the recap. NVIDIA currently sponsors this.',
  },
  {
    name: 'Build events, demo nights & hackathons',
    body: 'Beyond talks, we run hands-on build events, demo nights, and hackathons where practitioners ship real things with your tools in the room. Sponsor a format, set a challenge, or put your platform in front of builders.',
  },
  {
    name: 'Credits & compute partner',
    body: 'Provide API credits, GPU time, or platform access for our build events and hackathons. Practitioners try your product on a real problem, the highest-signal way to earn adoption. Credits partners, and partners beyond compute, are welcome to reach out.',
  },
  {
    name: 'Platform partner',
    body: 'Multi-event partnership. Co-marketing across the newsletter and a growing practitioner community, the events site, and on-stage acknowledgements. Limited to partners whose product or platform serves AI practitioners directly.',
  },
];
---
<BaseLayout
  title="Sponsors & Partners · The AI Runtime"
  description="The partners who help put on The AI Runtime: Microsoft hosts the space, NVIDIA covers food and drinks, and HackerSquad is the technology partner."
>
  <Section eyebrow="Sponsors & Partners" title="The companies that help us put on better meetups">
    <p class="lead dim">
      The AI Runtime is independent and practitioner-first. A small number of partners make the
      meetups happen: Microsoft hosts the space in Kendall Square, NVIDIA covers the food and
      drinks, and HackerSquad is the technology partner. A genuine thanks to all three.
    </p>
  </Section>

  <Section eyebrow="Current sponsors" title="Practitioner-grade partners">
    <ul class="logos-strip">
      {platformPartners.map((p) => (
        <li>
          <a href={p.url} target="_blank" rel="noopener" aria-label={p.name}>
            <span class="wordmark">{p.name}</span>
          </a>
        </li>
      ))}
    </ul>

    <ul class="grid">
      {platformPartners.map((p) => (
        <li>
          <a href={p.url} target="_blank" rel="noopener">
            <span class="name">{p.name}</span>
            <span class="role muted">{p.role}</span>
          </a>
          <p class="dim">{p.blurb}</p>
        </li>
      ))}
      <li class="placeholder">
        <span class="name muted">Your venue here</span>
        <span class="role muted">Venue partner · Boston</span>
        <p class="dim">We're looking for a recurring Boston venue host. <a href="/host">Run an event →</a></p>
      </li>
    </ul>
  </Section>

  <Section eyebrow="Ways to partner" title="What we offer">
    <ul class="tiers">
      {tiers.map((t) => (
        <li>
          <h3>{t.name}</h3>
          <p class="dim">{t.body}</p>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Interested?" title="Tell us what you have in mind">
    <p class="dim wide">
      Drop a line with what you're offering (venue, food, API or compute credits, a hackathon
      challenge, or a multi-event partnership), which city, and the timeframe. We'll reply within
      a few days.
    </p>
    <p>
      <a class="btn" href="mailto:info@theairuntime.com?subject=Sponsorship%20interest">info@theairuntime.com</a>
    </p>
  </Section>
</BaseLayout>

<style>
  .lead { max-width: 42rem; }

  /* Horizontal logo strip at the top, conventional sponsors layout */
  .logos-strip {
    list-style: none;
    padding: 1.25rem;
    margin: 0 0 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
    align-items: center;
    justify-content: center;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .logos-strip li { display: flex; align-items: center; }
  .logos-strip a {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--text);
    transition: opacity 140ms ease;
  }
  .logos-strip a:hover { opacity: 0.7; text-decoration: none; }
  .logos-strip .wordmark {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--text);
    padding: 0.4rem 0.85rem;
    border-left: 3px solid var(--accent);
  }

  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .grid li {
    padding: 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 140ms ease;
  }
  .grid li:hover { border-color: var(--border-strong); }
  .grid li.placeholder { border-style: dashed; }
  .grid a { display: flex; flex-direction: column; text-decoration: none; color: var(--text); gap: 0.4rem; }
  .grid .name {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .grid .role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .grid p { margin: 0.75rem 0 0; }

  .tiers {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .tiers li {
    padding: 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .tiers h3 { font-family: var(--font-mono); margin-bottom: 0.4rem; }
  .wide { max-width: 42rem; }
</style>
