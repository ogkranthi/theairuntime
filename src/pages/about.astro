---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Blink from '../components/Blink.astro';
import ContactCTA from '../components/ContactCTA.astro';
import SubstackEmbed from '../components/SubstackEmbed.astro';
import { PILLARS } from '../lib/pillars';

const pillars = PILLARS.map((p) => ({ key: p.key, name: p.label, body: p.tagline }));
---
<BaseLayout
  title="About · The AI Runtime"
  description="The publication where AI practitioners share what they've learned. Founded by Kranthi Manchikanti, AI Architect at Microsoft, based in Boston."
>
  <Section eyebrow="The publication">
    <div class="hero">
      <div>
        <h1>Between the model and the product</h1>
        <p class="lede dim">
          The AI Runtime is the publication where AI practitioners share what they've learned. We cover the
          operational layer where AI systems actually run (AI model reliability engineering, vertical
          agents, and lessons from the trenches) and the stories from people shipping serious AI in
          production.
        </p>
        <p class="dim">
          Practitioner-grade content: specific, sourced, and forward-looking. The kind of pieces you'd
          forward to your team.
        </p>
      </div>
      <div class="art"><Blink size={140} showMotion={true} showCheeks={true} /></div>
    </div>
  </Section>

  <Section eyebrow="Editorial pillars" title="What we cover">
    <ul class="pillars">
      {pillars.map((p, i) => (
        <li>
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3><a href={`/topics/${p.key}`}>{p.name}</a></h3>
            <p class="dim">{p.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Founder" title="Kranthi Manchikanti" narrow>
    <div class="founder">
      <p class="dim">
        Kranthi is founder and editor-in-chief of The AI Runtime. He's an AI Architect at Microsoft based
        in Boston, building the publication and the Boston meetup as a long-term home for AI practitioners.
      </p>
      <p>
        <a href="https://www.linkedin.com/in/kranthimanchikanti/">Connect on LinkedIn →</a>
      </p>
    </div>
  </Section>

  <Section eyebrow="Subscribe" title="Get The AI Runtime in your inbox">
    <p class="dim wide">
      Free, weekly, anti-hype. One issue a week with production lessons from AI practitioners.
      The kind of piece you'd forward to your team.
    </p>
    <SubstackEmbed
      source="about-page"
      headline="Practitioner-grade. New issues every week."
      subhead="Evals, agents, inference, reliability, cost. No vendor pitches."
    />
  </Section>

  <Section>
    <ContactCTA />
  </Section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (max-width: 720px) { .hero { grid-template-columns: 1fr; } }
  .lede { font-size: 1.1rem; max-width: 38rem; margin-top: 1rem; }
  .art { display: flex; justify-content: center; }
  .pillars {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .pillars li {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .pillars h3 { margin: 0 0 0.3rem; }
  .pillars h3 a { color: var(--text); text-decoration: none; }
  .pillars h3 a:hover { color: var(--accent); }
  .num {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    font-size: 1.25rem;
  }
  .founder { max-width: 38rem; }
  .wide { max-width: 42rem; }
</style>
