---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Blink from '../components/Blink.astro';
import ContactCTA from '../components/ContactCTA.astro';
import SubstackEmbed from '../components/SubstackEmbed.astro';
import AskQuestion from '../components/AskQuestion.astro';
import CredibilityStrip from '../components/CredibilityStrip.astro';
import StatBand from '../components/StatBand.astro';

const pillars = [
  { name: 'Evals & Observability', body: 'How practitioners know if AI works in production.' },
  { name: 'Agents in Production', body: 'Patterns that survive contact with real users.' },
  { name: 'Inference & Serving', body: 'What actually runs in production at scale.' },
  { name: 'Reliability & Incidents', body: 'Postmortems, drift, recovery patterns.' },
  { name: 'Cost & Performance', body: 'The economics of running AI.' },
];
---
<BaseLayout
  title="About · The AI Runtime"
  description="The AI Runtime is a community of AI practitioners: a weekly newsletter on production AI, monthly in-person meetups in Boston, and hands-on labs. Founded by Kranthi Manchikanti, AI Architect at Microsoft, based in Boston."
>
  <Section eyebrow="The community">
    <div class="hero">
      <div>
        <h1>Between the model and the product</h1>
        <p class="lede dim">
          The AI Runtime is a community of AI practitioners shipping AI to production who read, meet,
          and build together. A free weekly newsletter, monthly in-person meetups in Boston, and
          hands-on labs on real problems. The focus is Vertical AI Agents, Model Reliability
          Engineering, and the lessons from the trenches of shipping AI.
        </p>
        <p class="dim">
          Practitioner-grade content: specific, sourced, and forward-looking. The kind of pieces you'd
          forward to your team.
        </p>
        <p><a href="/story">Read our story →</a></p>
      </div>
      <div class="art"><Blink size={140} showMotion={true} showCheeks={true} /></div>
    </div>
  </Section>

  <CredibilityStrip />

  <StatBand />

  <Section eyebrow="What we do" title="Read, meet, and build">
    <ul class="arms">
      <li>
        <span class="arm-k">Read</span>
        <h3>The weekly newsletter</h3>
        <p class="dim">A free weekly issue on Vertical AI Agents, Model Reliability Engineering, and lessons from the trenches of shipping AI.</p>
      </li>
      <li>
        <span class="arm-k">Meet</span>
        <h3>The Boston meetup</h3>
        <p class="dim">A monthly gathering in Cambridge. Two practitioner talks a night, real production stories, and the people who ship.</p>
      </li>
      <li>
        <span class="arm-k">Build</span>
        <h3>The Field Lab</h3>
        <p class="dim">Production-shaped AI problems and a build pilot, so practitioners work on real problems instead of demos.</p>
      </li>
    </ul>
  </Section>

  <Section eyebrow="Editorial pillars" title="What we cover">
    <ul class="pillars">
      {pillars.map((p, i) => (
        <li>
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{p.name}</h3>
            <p class="dim">{p.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </Section>

  <Section eyebrow="Founder" title="Kranthi Manchikanti" narrow>
    <div class="founder">
      <p class="dim">
        Kranthi is the founder of The AI Runtime. He's an AI Architect at Microsoft based in Boston,
        building the community, the newsletter, and the Boston meetup as a long-term home for AI
        practitioners.
      </p>
      <p>
        <a href="https://www.linkedin.com/in/kranthimanchikanti/">Connect on LinkedIn →</a>
      </p>
    </div>
  </Section>

  <Section eyebrow="Subscribe" title="Get The AI Runtime in your inbox">
    <p class="dim wide">
      Free, weekly, anti-hype. One issue a week with production lessons from AI practitioners.
      The kind of piece you'd forward to your team.
    </p>
    <SubstackEmbed
      source="about-page"
      headline="Practitioner-grade. New issues every week."
      subhead="Evals, agents, inference, reliability, cost. Production lessons from practitioners."
    />
  </Section>

  <Section eyebrow="Questions" title="Ask us a specific question">
    <AskQuestion eyebrow="" title="" subjectTag="About question" />
  </Section>

  <Section>
    <ContactCTA />
  </Section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (max-width: 720px) { .hero { grid-template-columns: 1fr; } }
  .lede { font-size: 1.1rem; max-width: 38rem; margin-top: 1rem; }
  .art { display: flex; justify-content: center; }
  .pillars {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .pillars li {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .num {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    font-size: 1.25rem;
  }
  .founder { max-width: 38rem; }
  .wide { max-width: 42rem; }
  .arms {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 760px) { .arms { grid-template-columns: 1fr; } }
  .arms li {
    padding: 1.5rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .arm-k {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
  }
  .arms h3 { margin: 0.5rem 0 0.4rem; font-size: 1.1rem; }
  .arms p { margin: 0; font-size: 0.95rem; }
</style>
