---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import CohortCTA from '../../components/CohortCTA.astro';
import SubstackEmbed from '../../components/SubstackEmbed.astro';
import { HERO_BRIEF_SLUG, intakeUrl } from '../../lib/field-briefs';

const problems = await getCollection('problems');
const briefCount = problems.length;
const heroBrief = problems.find((p) => p.id === HERO_BRIEF_SLUG);
---
<BaseLayout
  title="Field Lab · The AI Runtime"
  description="The AI Runtime Field Lab: a library of real, production-shaped AI problems and a build pilot. Build on real problems, not demos."
  chrome="lab"
>
  <Section eyebrow="The AI Runtime Field Lab" title="Build production-grade AI on real problems" flush>
    <p class="lede dim">
      The Field Lab is where builders work on real, production-shaped AI problems instead of random
      demos. Browse the problem library, submit a problem from your own work, or join the build pilot.
    </p>
    <p class="jump">
      <a class="btn" href={intakeUrl()} target="_blank" rel="noopener">Submit a problem</a>
      <a class="btn btn-ghost" href="/briefs">Browse the briefs</a>
    </p>
  </Section>

  <Section eyebrow="Field Briefs" title="A library of real AI problems">
    <p class="dim wide">
      {briefCount} sanitized, production-shaped problems scoped to be buildable and testable, each with
      a stated reliability bar: the pain, the workflow, inputs and outputs, evaluation ideas, the
      boundaries, and a reliability target.
    </p>
    {heroBrief && <p class="muted small">Start with the featured brief: {heroBrief.data.one_line}</p>}
    <p class="jump">
      <a class="btn" href="/briefs">Browse Field Briefs →</a>
      {heroBrief && <a class="btn btn-ghost" href={`/briefs/${heroBrief.id}`}>Read the featured brief</a>}
    </p>
  </Section>

  <CohortCTA />

  <Section eyebrow="For students" title="Free tools to start building" narrow>
    <p class="dim">
      Most tools practitioners use in production are free for students: Microsoft for Students, NVIDIA,
      free compute and courses, plus the free Field Guide and meetup entry from The AI Runtime.
    </p>
    <p><a class="btn btn-ghost" href="/students">See student resources →</a></p>
  </Section>

  <Section eyebrow="Subscribe" title="Stay in the loop" narrow>
    <p class="dim">
      New briefs, the next pilot run, and weekly production lessons from practitioners. Free.
    </p>
    <SubstackEmbed
      source="field-lab"
      headline="The AI Runtime newsletter"
      subhead="Evals, agents, inference, reliability, cost. New issues every week."
      buttonLabel="Subscribe free"
    />
  </Section>
</BaseLayout>

<style>
  .lede { font-size: 1.15rem; max-width: 44rem; }
  .jump { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .wide { max-width: 44rem; }
  .small { font-size: 0.9rem; }
</style>
