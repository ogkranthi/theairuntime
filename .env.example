# Public env vars (PUBLIC_-prefixed are exposed to the client by Astro).

# Where the "Join the cohort" buttons send students. Set to one of:
#  - a Luma cohort/event page (matches how the meetup series is run), or
#  - a Tally or Google Form application URL, or
#  - a mailto: fallback.
# When the on-page waitlist (KV) is not enabled, the buttons use this link.
PUBLIC_COHORT_JOIN_URL=https://luma.com/tair

# Cloudflare Web Analytics beacon token. When unset, no beacon loads.
# PUBLIC_CF_BEACON_TOKEN=

# Field Briefs (Field Lab problem library) CTA destinations.
# "Submit a Problem" routes here (the existing problem intake form). Failure
# briefs append ?family=<id> to prefill the failure family.
PUBLIC_PROBLEM_INTAKE_URL=https://tally.so/r/your-problem-intake
# "Join the builder interest list" routes here (external form for now).
PUBLIC_BUILDER_INTEREST_URL=https://tally.so/r/your-builder-interest

# Server-side (not exposed to client), set in the Cloudflare dashboard:
#  SUBSTACK_ORIGIN     - publication origin, defaults to https://theairuntime.com
#  LEAD_WEBHOOK_URL    - optional Slack/Make/Zapier mirror for subscribe leads
#  SIGNAL_WEBHOOK_URL  - optional webhook for /signal question submissions
# KV namespace WAITLIST and the AI binding are configured in wrangler.toml.
